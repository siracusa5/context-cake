---
import { codeToHtml } from 'shiki';
import type { PackExplorerData } from '../lib/pack-explorer';

interface Props {
	defaultFile?: string;
	explorer: PackExplorerData;
	featuredFiles?: Array<{ label: string; path: string }>;
	id: string;
	title?: string;
}

const { defaultFile, explorer, featuredFiles = [], id, title = 'Pack explorer' } = Astro.props;
const selectedFile = defaultFile ?? explorer.files[0]?.path ?? '';
const validPaths = new Set(explorer.files.map((file) => file.path));
const quickFiles = featuredFiles.filter((file) => validPaths.has(file.path));

const renderedFiles = await Promise.all(
	explorer.files.map(async (file) => ({
		...file,
		sourceHtml: await codeToHtml(file.content, {
			lang: file.language,
			theme: 'github-dark-default',
		}),
	})),
);
---

<section class="pack-explorer" data-pack-explorer={id}>
	<div class="explorer-sidebar">
		<div class="terminal-head">
			<span>tree</span>
			<code>{explorer.rootLabel}</code>
		</div>
		<div class="tree-lines" role="tree" aria-label={title}>
			{explorer.treeEntries.map((entry) =>
				entry.kind === 'dir' ? (
					<button
						class="tree-row dir"
						data-tree-row
						data-path={entry.path}
						data-folder-path={entry.path}
						style={`--depth:${entry.depth}`}
						role="treeitem"
						type="button"
						aria-expanded="true"
					>
						<span class="chevron" aria-hidden="true">▸</span>
						<span class="tree-name">{entry.name}</span>
					</button>
				) : (
					<button
						class={`tree-row file${entry.path === selectedFile ? ' active' : ''}`}
						data-tree-row
						data-path={entry.path}
						data-file-trigger={entry.path}
						style={`--depth:${entry.depth}`}
						role="treeitem"
						type="button"
					>
						<span class="dot" aria-hidden="true"></span>
						<span class="tree-name">{entry.name}</span>
					</button>
				),
			)}
		</div>
	</div>

	<div class="explorer-preview">
		{renderedFiles.map((file) => (
			<article
				class={`preview-pane${file.path === selectedFile ? ' active' : ''}`}
				data-file-panel={file.path}
				data-has-rendered={file.renderedHtml ? 'true' : 'false'}
				hidden={file.path !== selectedFile}
			>
				<header class="preview-head">
					<div class="preview-title">
						<p class="preview-label">{file.renderedHtml ? 'Preview' : 'Source'}</p>
						<h3>{file.path}</h3>
					</div>
					<div class="preview-meta">
						{quickFiles.length > 0 && (
							<div class="preview-jump" aria-label="Featured files">
								{quickFiles.map((featured) => (
									<button
										class={`jump-chip${featured.path === file.path ? ' active' : ''}`}
										data-file-trigger={featured.path}
										type="button"
									>
										{featured.label}
									</button>
								))}
							</div>
						)}
						{file.renderedHtml ? (
							<div class="view-toggle" role="group" aria-label="View mode">
								<button class="view-btn" data-view="rendered" type="button" aria-pressed="true">Rendered</button>
								<button class="view-btn" data-view="source" type="button" aria-pressed="false">Source</button>
							</div>
						) : (
							<span class="preview-lang">{file.language}</span>
						)}
					</div>
				</header>
				{file.renderedHtml && (
					<div class="preview-body view-rendered markdown-body" data-view-body="rendered" set:html={file.renderedHtml} />
				)}
				<div
					class="preview-body view-source"
					data-view-body="source"
					hidden={file.renderedHtml != null}
					set:html={file.sourceHtml}
				/>
				<span class="scroll-fade" aria-hidden="true"></span>
			</article>
		))}
	</div>
</section>

<style>
	.pack-explorer {
		display: grid;
		grid-template-columns: minmax(16rem, 22rem) minmax(0, 1fr);
		gap: 1rem;
	}
	.explorer-sidebar,
	.preview-pane {
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 76%, transparent);
	}
	.explorer-sidebar {
		overflow: hidden;
		align-self: start;
		position: sticky;
		top: 1rem;
	}
	.terminal-head,
	.preview-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 1rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.terminal-head span,
	.preview-label,
	.preview-lang {
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	.terminal-head code {
		color: var(--cc-text);
		font-family: var(--cc-font-mono);
		font-size: 0.88rem;
	}
	.tree-lines {
		padding: 0.5rem 0;
		font-family: var(--cc-font-mono);
		font-size: 0.86rem;
		max-height: 34rem;
		overflow: auto;
	}
	.tree-row {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		width: 100%;
		padding: 0.2rem 0.9rem 0.2rem calc(0.9rem + var(--depth, 0) * 1rem);
		box-sizing: border-box;
		border: 0;
		background: transparent;
		color: var(--cc-text-body);
		text-align: left;
		font: inherit;
		cursor: pointer;
	}
	.tree-row:hover,
	.tree-row.active {
		background: rgba(243, 239, 230, 0.06);
		color: var(--cc-text);
	}
	.tree-row.dir .tree-name {
		color: var(--cc-text);
		font-weight: 600;
	}
	.chevron {
		flex: 0 0 auto;
		width: 0.8rem;
		color: var(--cc-text-faint);
		transition: transform 0.12s ease;
	}
	.tree-row.dir[aria-expanded='true'] .chevron {
		transform: rotate(90deg);
	}
	.dot {
		flex: 0 0 auto;
		width: 0.35rem;
		height: 0.35rem;
		margin: 0 0.22rem;
		border-radius: 50%;
		background: var(--cc-text-faint);
	}
	.tree-name {
		overflow-wrap: anywhere;
	}
	.preview-pane {
		position: relative;
		overflow: hidden;
		min-width: 0;
	}
	.preview-head {
		align-items: start;
	}
	.preview-title {
		min-width: 0;
	}
	.preview-head h3 {
		margin: 0.25rem 0 0;
		color: var(--cc-text);
		font-family: var(--cc-font-mono);
		font-size: 0.95rem;
		line-height: 1.35;
		word-break: break-word;
	}
	.preview-meta {
		display: grid;
		justify-items: end;
		gap: 0.6rem;
	}
	.preview-jump {
		display: flex;
		flex-wrap: wrap;
		justify-content: end;
		gap: 0.45rem;
		max-width: 22rem;
	}
	.jump-chip {
		min-height: 2.1rem;
		padding: 0 0.7rem;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		background: transparent;
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0;
		cursor: pointer;
	}
	.jump-chip.active,
	.jump-chip:hover {
		border-color: color-mix(in srgb, var(--cc-layer-team) 55%, var(--cc-border));
		background: color-mix(in srgb, var(--cc-layer-team) 16%, transparent);
		color: var(--cc-text);
	}
	.view-toggle {
		display: inline-flex;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		overflow: hidden;
	}
	.view-btn {
		padding: 0.32rem 0.72rem;
		border: 0;
		background: transparent;
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0;
		cursor: pointer;
	}
	.view-btn[aria-pressed='true'] {
		background: color-mix(in srgb, var(--cc-layer-team) 20%, transparent);
		color: var(--cc-text);
	}
	.preview-body {
		max-height: 40rem;
		overflow: auto;
	}
	.preview-body[hidden] {
		display: none;
	}
	.scroll-fade {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 2.25rem;
		background: linear-gradient(
			to bottom,
			transparent,
			color-mix(in srgb, var(--cc-surface-solid) 92%, transparent)
		);
		pointer-events: none;
		opacity: 0;
		transition: opacity var(--cc-transition);
	}
	.preview-pane[data-overflowing] .scroll-fade {
		opacity: 1;
	}
	.view-source :global(.shiki) {
		margin: 0;
		padding: 1rem;
		background: transparent !important;
		font-family: var(--cc-font-mono);
		font-size: 0.86rem;
		line-height: 1.65;
	}
	.view-source :global(.shiki code) {
		white-space: pre-wrap;
		word-break: break-word;
	}

	/* Rendered markdown prose */
	.markdown-body {
		padding: 1.25rem 1.4rem 1.6rem;
		color: var(--cc-text-body);
		line-height: 1.62;
	}
	.markdown-body :global(> :first-child) {
		margin-top: 0;
	}
	.markdown-body :global(h1),
	.markdown-body :global(h2),
	.markdown-body :global(h3),
	.markdown-body :global(h4) {
		color: var(--cc-text);
		line-height: 1.25;
		margin: 1.6rem 0 0.6rem;
	}
	.markdown-body :global(h1) {
		font-size: 1.5rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.markdown-body :global(h2) {
		font-size: 1.2rem;
		padding-bottom: 0.3rem;
		border-bottom: 1px solid color-mix(in srgb, var(--cc-border) 60%, transparent);
	}
	.markdown-body :global(h3) { font-size: 1.05rem; }
	.markdown-body :global(h4) { font-size: 0.95rem; }
	.markdown-body :global(p),
	.markdown-body :global(ul),
	.markdown-body :global(ol),
	.markdown-body :global(blockquote),
	.markdown-body :global(table) {
		margin: 0.7rem 0;
	}
	.markdown-body :global(ul),
	.markdown-body :global(ol) {
		padding-left: 1.4rem;
	}
	.markdown-body :global(li) { margin: 0.3rem 0; }
	.markdown-body :global(a) {
		color: var(--cc-layer-team);
		text-underline-offset: 0.2em;
	}
	.markdown-body :global(strong) { color: var(--cc-text); }
	.markdown-body :global(code) {
		font-family: var(--cc-font-mono);
		font-size: 0.86em;
		padding: 0.1rem 0.35rem;
		border-radius: 4px;
		background: color-mix(in srgb, var(--cc-surface) 60%, transparent);
	}
	.markdown-body :global(pre) {
		margin: 0.9rem 0;
		padding: 0.9rem 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		overflow-x: auto;
	}
	.markdown-body :global(pre code) {
		padding: 0;
		background: transparent;
		font-size: 0.85rem;
		line-height: 1.6;
	}
	.markdown-body :global(pre .shiki),
	.markdown-body :global(pre.shiki) {
		background: transparent !important;
	}
	.markdown-body :global(blockquote) {
		padding: 0.2rem 0 0.2rem 1rem;
		border-left: 3px solid color-mix(in srgb, var(--cc-layer-team) 50%, var(--cc-border));
		color: var(--cc-text-body);
	}
	.markdown-body :global(table) {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.92rem;
		display: block;
		overflow-x: auto;
	}
	.markdown-body :global(th),
	.markdown-body :global(td) {
		padding: 0.45rem 0.7rem;
		border: 1px solid var(--cc-border);
		text-align: left;
	}
	.markdown-body :global(th) {
		color: var(--cc-text);
		background: color-mix(in srgb, var(--cc-surface) 55%, transparent);
	}
	.markdown-body :global(hr) {
		margin: 1.4rem 0;
		border: 0;
		border-top: 1px solid var(--cc-border);
	}
	@media (max-width: 920px) {
		.pack-explorer {
			grid-template-columns: 1fr;
		}
		.explorer-sidebar {
			position: static;
		}
		.preview-meta,
		.preview-jump {
			justify-items: start;
			justify-content: start;
		}
		.preview-body {
			max-height: none;
		}
	}
</style>

<script>
	function ancestorsOf(p: string): string[] {
		const parts = p.split('/');
		const anc: string[] = [];
		for (let i = 1; i < parts.length; i += 1) anc.push(parts.slice(0, i).join('/'));
		return anc;
	}

	function updateOverflow(pane: HTMLElement) {
		const body = pane.querySelector<HTMLElement>('.preview-body:not([hidden])');
		if (!body) {
			pane.removeAttribute('data-overflowing');
			return;
		}
		const hasMoreBelow = body.scrollHeight - body.clientHeight - body.scrollTop > 4;
		pane.toggleAttribute('data-overflowing', hasMoreBelow);
	}

	// Coalesce scroll/resize bursts to one measurement per frame per pane.
	const overflowScheduled = new WeakSet<HTMLElement>();
	function scheduleOverflow(pane: HTMLElement) {
		if (overflowScheduled.has(pane)) return;
		overflowScheduled.add(pane);
		requestAnimationFrame(() => {
			overflowScheduled.delete(pane);
			updateOverflow(pane);
		});
	}

	for (const explorer of document.querySelectorAll('[data-pack-explorer]')) {
		const rows = Array.from(explorer.querySelectorAll<HTMLElement>('[data-tree-row]'));
		const folders = Array.from(explorer.querySelectorAll<HTMLElement>('[data-folder-path]'));
		const triggers = explorer.querySelectorAll<HTMLElement>('[data-file-trigger]');
		const panes = explorer.querySelectorAll<HTMLElement>('[data-file-panel]');

		for (const pane of panes) {
			for (const body of pane.querySelectorAll<HTMLElement>('.preview-body')) {
				body.addEventListener('scroll', () => scheduleOverflow(pane), { passive: true });
			}
			updateOverflow(pane);
		}
		window.addEventListener('resize', () => {
			// Only the visible pane's fade can change on resize.
			const active = explorer.querySelector<HTMLElement>('[data-file-panel]:not([hidden])');
			if (active) scheduleOverflow(active);
		});

		// --- collapsible folders ---
		const expanded = new Set<string>(folders.map((f) => f.dataset.folderPath || ''));
		function refreshTree() {
			for (const row of rows) {
				const p = row.dataset.path || '';
				row.hidden = !ancestorsOf(p).every((a) => expanded.has(a));
			}
			for (const f of folders) {
				const fp = f.dataset.folderPath || '';
				f.setAttribute('aria-expanded', expanded.has(fp) ? 'true' : 'false');
			}
		}
		for (const f of folders) {
			f.addEventListener('click', () => {
				const fp = f.dataset.folderPath || '';
				if (expanded.has(fp)) expanded.delete(fp);
				else expanded.add(fp);
				refreshTree();
			});
		}
		refreshTree();

		// --- file selection ---
		function selectFile(target: string) {
			for (const t of triggers) t.classList.toggle('active', t.getAttribute('data-file-trigger') === target);
			for (const pane of panes) {
				const isActive = pane.getAttribute('data-file-panel') === target;
				pane.toggleAttribute('hidden', !isActive);
				pane.classList.toggle('active', isActive);
				if (isActive) updateOverflow(pane);
			}
		}
		for (const trigger of triggers) {
			trigger.addEventListener('click', () => {
				const target = trigger.getAttribute('data-file-trigger');
				if (target) selectFile(target);
			});
		}

		// --- rendered / source toggle (global across panes) ---
		function applyView(mode: 'rendered' | 'source') {
			for (const pane of panes) {
				const hasRendered = pane.getAttribute('data-has-rendered') === 'true';
				const showRendered = hasRendered && mode === 'rendered';
				const rendered = pane.querySelector<HTMLElement>('[data-view-body="rendered"]');
				const source = pane.querySelector<HTMLElement>('[data-view-body="source"]');
				if (rendered) rendered.hidden = !showRendered;
				if (source) source.hidden = showRendered;
				for (const btn of pane.querySelectorAll<HTMLElement>('.view-btn')) {
					btn.setAttribute('aria-pressed', btn.dataset.view === mode ? 'true' : 'false');
				}
				updateOverflow(pane);
			}
		}
		for (const btn of explorer.querySelectorAll<HTMLElement>('.view-btn')) {
			btn.addEventListener('click', () => applyView((btn.dataset.view as 'rendered' | 'source') || 'rendered'));
		}
		applyView('rendered');
	}
</script>
