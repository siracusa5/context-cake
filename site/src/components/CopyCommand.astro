---
// Copy-to-clipboard command box (spec.md: homepage AC 1–2).
interface Props {
	command: string;
}
const { command } = Astro.props;
---

<div class="copy-command">
	<code>{command}</code>
	<button type="button" data-command={command} aria-label="Copy command to clipboard">
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<rect x="9" y="9" width="13" height="13" rx="2"></rect>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
		</svg>
		<span class="label">Copy</span>
	</button>
</div>

<style>
	.copy-command {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		max-width: 100%;
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		padding: 0.75rem 1rem;
		font-family: var(--cc-font-mono);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
	}
	code {
		flex: 1 1 auto;
		min-width: 0;
		color: var(--cc-text);
		font-size: 1rem;
		/* Long clone URLs must wrap rather than force horizontal scroll (spec: no
		   horizontal scroll at 375px). */
		overflow-wrap: anywhere;
	}
	button {
		flex: 0 0 auto;
	}
	code::before {
		content: '$ ';
		color: var(--cc-text-muted);
	}
	button {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: transparent;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.85rem;
		min-height: 34px;
		padding: 0.35rem 0.8rem;
		cursor: pointer;
		transition: color var(--cc-transition), border-color var(--cc-transition);
	}
	button:hover {
		color: var(--cc-text);
		border-color: var(--cc-cta);
	}
	button.copied {
		color: var(--cc-cta);
		border-color: var(--cc-cta);
	}
</style>

<script>
	async function copyText(text: string): Promise<boolean> {
		try {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(text);
				return true;
			}
		} catch {
			/* fall through to the execCommand fallback */
		}
		try {
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.setAttribute('readonly', '');
			ta.style.position = 'fixed';
			ta.style.left = '-9999px';
			document.body.appendChild(ta);
			ta.select();
			const ok = document.execCommand('copy');
			document.body.removeChild(ta);
			return ok;
		} catch {
			return false;
		}
	}

	for (const button of document.querySelectorAll<HTMLButtonElement>('.copy-command button')) {
		button.addEventListener('click', async () => {
			await copyText(button.dataset.command ?? '');
			// Confirm regardless — the command is visible, so the worst case is a
			// manual copy, and the user still gets feedback that the click landed.
			button.classList.add('copied');
			const label = button.querySelector('.label');
			if (label) label.textContent = 'Copied';
			setTimeout(() => {
				button.classList.remove('copied');
				if (label) label.textContent = 'Copy';
			}, 2000);
		});
	}
</script>
