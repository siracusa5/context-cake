---
// Copy-to-clipboard command box (spec.md: homepage AC 1–2).
import { codeToHtml } from 'shiki';
import Icon from './Icon.astro';

interface Props {
	command: string;
}
const { command } = Astro.props;
const html = await codeToHtml(`$ ${command}`, {
	lang: 'bash',
	theme: 'github-dark-default',
});
---

<div class="copy-command">
	<div class="command-view" set:html={html} />
	<button type="button" data-command={command} aria-label="Copy command to clipboard">
		<Icon name="copy" size={16} />
		<span class="label">Copy</span>
	</button>
</div>

<style>
	.copy-command {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		max-width: 100%;
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		padding: 0.75rem 1rem;
		font-family: var(--cc-font-mono);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
	}
	.command-view {
		flex: 1 1 auto;
		min-width: 0;
	}
	button {
		flex: 0 0 auto;
	}
	.command-view :global(.shiki) {
		margin: 0;
		padding: 0;
		background: transparent !important;
		font-family: var(--cc-font-mono);
		font-size: 0.96rem;
		line-height: 1.55;
		overflow-wrap: anywhere;
		white-space: pre-wrap;
	}
	.command-view :global(.shiki code) {
		white-space: pre-wrap;
		word-break: break-word;
	}
	button {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: transparent;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.85rem;
		min-height: 34px;
		padding: 0.35rem 0.8rem;
		cursor: pointer;
		transition: color var(--cc-transition), border-color var(--cc-transition);
	}
	button:hover {
		color: var(--cc-text);
		border-color: var(--cc-cta);
	}
	button.copied {
		color: var(--cc-cta);
		border-color: var(--cc-cta);
	}
</style>

<script>
	async function copyText(text: string): Promise<boolean> {
		try {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(text);
				return true;
			}
		} catch {
			/* fall through to execCommand */
		}
		// Insecure context (e.g. LAN http:// preview) or a denied clipboard
		// permission: execCommand is deprecated but still copies everywhere,
		// and the spec's AC is that the button copies — copy the bare command,
		// not the rendered "$ " prompt.
		try {
			const ta = document.createElement('textarea');
			ta.value = text;
			ta.setAttribute('readonly', '');
			ta.style.position = 'fixed';
			ta.style.opacity = '0';
			document.body.appendChild(ta);
			ta.select();
			const ok = document.execCommand('copy');
			ta.remove();
			return ok;
		} catch {
			return false;
		}
	}

	// Last-resort fallback when both clipboard paths fail: select the command
	// text in the visible code view so the user can copy it themselves
	// (Cmd/Ctrl-C). Excludes the rendered "$ " prompt so the paste is runnable.
	function selectCommandText(button: HTMLButtonElement) {
		const view = button
			.closest('.copy-command')
			?.querySelector<HTMLElement>('.command-view code');
		if (!view) return;
		const selection = window.getSelection();
		if (!selection) return;
		const range = document.createRange();
		range.selectNodeContents(view);
		// Skip past the leading "$ " prompt so a manual copy pastes a runnable
		// command. The prompt is the first rendered characters of the block.
		const walker = document.createTreeWalker(view, NodeFilter.SHOW_TEXT);
		const first = walker.nextNode();
		if (first?.textContent?.startsWith('$')) {
			const skip = first.textContent.startsWith('$ ') ? 2 : 1;
			if (first.textContent.length > skip) range.setStart(first, skip);
			else {
				const next = walker.nextNode();
				if (next) range.setStart(next, next.textContent?.startsWith(' ') ? 1 : 0);
			}
		}
		selection.removeAllRanges();
		selection.addRange(range);
	}

	for (const button of document.querySelectorAll<HTMLButtonElement>('.copy-command button')) {
		button.addEventListener('click', async () => {
			const ok = await copyText(button.dataset.command ?? '');
			const label = button.querySelector('.label');
			if (ok) {
				button.classList.add('copied');
				if (label) label.textContent = 'Copied';
			} else {
				selectCommandText(button);
				if (label) label.textContent = 'Selected — press ⌘/Ctrl-C';
			}
			setTimeout(() => {
				button.classList.remove('copied');
				if (label) label.textContent = 'Copy';
			}, 2000);
		});
	}
</script>
