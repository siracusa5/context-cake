---
// Base layout for marketing pages (/, /install, /demo, /changelog).
// Docs pages use Starlight's own shell instead.
import '@fontsource/bricolage-grotesque/400.css';
import '@fontsource/bricolage-grotesque/500.css';
import '@fontsource/bricolage-grotesque/600.css';
import '@fontsource/bricolage-grotesque/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/tokens.css';
import StrataMark from '../components/StrataMark.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

// Absolute URLs for canonical + OpenGraph (Astro.site = https://contextcake.com).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link rel="canonical" href={canonical} />
			<meta property="og:url" content={canonical} />
			<meta property="og:image" content={ogImage} />
			<meta property="og:image:width" content="1200" />
			<meta property="og:image:height" content="630" />
			<meta name="twitter:card" content="summary_large_image" />
			<meta name="twitter:title" content={title} />
			<meta name="twitter:description" content={description} />
			<meta name="twitter:image" content={ogImage} />
	</head>
	<body>
		<header class="nav">
			<a href="/" class="brand" aria-label="ContextCake home">
				<StrataMark size={22} />
				<span>ContextCake</span>
			</a>
			<nav aria-label="Main">
				<a href="/packs">Packs</a>
				<a href="/docs/getting-started/installation">Docs</a>
				<a href="/demo">Demo</a>
				<a href="/install">Install</a>
				<a href="https://github.com/siracusa5/context-cake">GitHub</a>
			</nav>
		</header>
		<slot />
		<footer class="footer">
			<p>ContextCake — conflicts surfaced, not hidden. MIT licensed.</p>
		</footer>
	</body>
</html>

<style>
	:global(body) {
		margin: 0;
		background: var(--cc-canvas);
		color: var(--cc-text-body);
		font-family: var(--cc-font-body);
		line-height: 1.6;
	}
	:global(h1, h2, h3) {
		font-family: var(--cc-font-heading);
		color: var(--cc-text);
	}
	:global(a) {
		color: var(--cc-text);
	}
	:global(:focus-visible) {
		outline: 2px solid var(--cc-cta);
		outline-offset: 2px;
	}
	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		max-width: 72rem;
		margin: 0 auto;
		padding: 1.25rem 1.5rem;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
		color: var(--cc-text);
	}
	.nav nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
	}
	@media (max-width: 480px) {
		.nav nav {
			gap: 1rem;
		}
	}
	.nav nav a {
		text-decoration: none;
		color: var(--cc-text-body);
		transition: color var(--cc-transition);
	}
	.nav nav a:hover {
		color: var(--cc-text);
	}
	.footer {
		max-width: 72rem;
		margin: 4rem auto 0;
		padding: 2rem 1.5rem;
		border-top: 1px solid var(--cc-border);
		color: var(--cc-text-muted);
		font-size: 0.9rem;
	}
</style>
