---
import Base from '../layouts/Base.astro';

// Point at index.html explicitly: Cloudflare Pages resolves the directory, but
// `astro dev` does not serve a trailing-slash directory index, so `/demo-app/`
// 404s the iframe in local dev.
const demoUrl = '/demo-app/index.html';

const narrativePoints = [
	{
		title: 'The answer keeps its source',
		body: 'The console shows a working answer without pretending every part came from the same place. Policy, team practice, and local judgment stay legible.',
	},
	{
		title: 'Disagreement stays visible',
		body: 'When one layer overrides another, the losing view does not vanish into edit history. It stays attached with its layer and date.',
	},
	{
		title: 'The full workflow is intact',
		body: 'This is the real console surface, hosted inside the main site, with overview, triage, conflicts, concept detail, and the grounded assistant.',
	},
];
---

<Base
	title="ContextCake demo"
	description="See the ContextCake console in context, with a clearer explanation of what the resolved view is proving."
>
	<main class="demo-page">
		<section class="hero">
			<div class="hero-copy">
				<p class="eyebrow">Demo</p>
				<h1>See how one team decision resolves without flattening the disagreement.</h1>
				<p class="lede">
					The surface below is the actual ContextCake console. Every value in it is real
					<code>resolver.mjs</code> output over the demo layers, generated at build time —
					not hand-authored. It is showing one problem well: how company policy, team
					practice, and local judgment can resolve into a usable answer without hiding where
					each part came from.
				</p>
				<div class="actions">
					<a class="cta primary" href={demoUrl} target="_blank" rel="noreferrer">Open full demo</a>
					<a class="cta" href="/docs/getting-started/first-cascade">Walk the first cascade</a>
					<a class="cta" href="/install">Install ContextCake</a>
				</div>
			</div>

			<aside class="scenario" aria-label="Demo framing">
				<p class="scenario-label">What to look for</p>
				<h2>One decision, three layers, one working view.</h2>
				<p>
					Start on the canvas or conflicts view. The point is not the interface chrome. The
					point is that the console keeps the winning answer, the dissent, and the provenance
					in the same place.
				</p>
			</aside>
		</section>

		<section class="frame-section">
			<div class="frame-wrap">
				<iframe
					class="demo-frame"
					src={demoUrl}
					title="ContextCake console demo"
					loading="eager"
				/>
			</div>
		</section>

		<section class="signals">
			<p class="eyebrow">What to notice</p>
			<h2>The demo should answer three questions quickly.</h2>
			<div class="signal-grid">
				{narrativePoints.map((point) => (
					<article class="signal">
						<h3>{point.title}</h3>
						<p>{point.body}</p>
					</article>
				))}
			</div>
		</section>
	</main>
</Base>

<style>
	.demo-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 3rem 1.5rem 2rem;
	}
	.hero,
	.signals {
		padding-bottom: 3rem;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
		gap: 2rem;
		align-items: start;
	}
	.eyebrow,
	.scenario-label {
		margin: 0 0 0.85rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	h1,
	h2,
	h3,
	p {
		letter-spacing: 0;
	}
	h1,
	h2,
	h3 {
		margin: 0;
	}
	h1 {
		max-width: 12ch;
		font-size: clamp(2.6rem, 5vw, 4.5rem);
		line-height: 0.96;
	}
	.lede,
	.scenario p,
	.signal p {
		color: var(--cc-text-body);
	}
	.lede {
		max-width: 58ch;
		margin: 1.4rem 0 0;
		font-size: clamp(1.08rem, 2vw, 1.22rem);
		line-height: 1.65;
	}
	.lede code {
		font-family: var(--cc-font-mono);
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: 4px;
		padding: 0.1rem 0.35rem;
		font-size: 0.85em;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 2rem;
	}
	.cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		color: var(--cc-text);
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
	}
	.cta.primary {
		background: var(--cc-cta);
		border-color: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.scenario,
	.signal,
	.frame-wrap {
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-lg);
		box-shadow: var(--cc-shadow-panel);
	}
	.scenario {
		padding: 1.3rem;
	}
	.scenario h2 {
		font-size: clamp(1.55rem, 3vw, 2.15rem);
		line-height: 1.02;
		margin-bottom: 0.9rem;
	}
	.scenario p {
		margin: 0;
	}
	.frame-section {
		padding-bottom: 3rem;
	}
	.frame-wrap {
		overflow: hidden;
		background: color-mix(in srgb, var(--cc-surface) 82%, transparent);
	}
	.demo-frame {
		display: block;
		width: 100%;
		height: clamp(28rem, 108vw, 44rem);
		border: 0;
		background: #0f1115;
	}
	@media (min-width: 640px) {
		.demo-frame {
			height: clamp(32rem, 82vh, 50rem);
		}
	}
	.signals h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 0.98;
		max-width: 14ch;
		margin-bottom: 1.5rem;
	}
	.signal-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.signal {
		padding: 1.3rem;
	}
	.signal h3 {
		font-size: 1.05rem;
		margin-bottom: 0.65rem;
	}
	@media (max-width: 900px) {
		.hero,
		.signal-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
