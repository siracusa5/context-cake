---
import Base from '../../layouts/Base.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const packSections = [
	['overview/', 'What ContextCake is, the problem it solves, and the mental model.'],
	['architecture/', 'Federated storage, the resolver, section merge, conflicts, OKF, and the MCP server.'],
	['getting-started/', 'Install, resolve your first cascade, write a layer, connect an agent.'],
	['examples/', 'A real OKF concept, a working layers.json, and a resolved read_file payload.'],
	['nuances/', 'The sharp edges: precedence, the trust boundary, conflicts-not-hidden.'],
	['tool-guides/', 'Use the pack with Claude Code, ChatGPT, Cursor, and Copilot.'],
];

const featuredPack = {
	name: 'ContextCake Context Pack',
	href: '/packs/contextcake',
	status: 'Free preview',
	summary:
		'Everything an AI agent needs to actually use ContextCake in your project — architecture, OKF, resolver, MCP, install, and the sharp edges.',
	bestFor: 'Developers adopting or building on ContextCake who want their AI assistant to know how it works.',
	benefits: [
		'Understand the architecture fast',
		'Get an agent productive with the MCP server',
		'Read the full pack free while it’s in preview',
	],
	includes: ['Overview + mental model', 'Architecture deep-dive', 'Getting-started guides', 'Real examples', 'Nuances & gotchas'],
	formats: ['Plain markdown files', 'Claude Code plugin', 'OKF-compatible structure'],
};

const heroPoints = [
	'Use the same pack across Claude, ChatGPT, Cursor, Copilot, and plain docs',
	'Inspect the files instead of guessing what is inside',
	'Keep team-specific edits in a local overlay',
];

const structurePreview = `contextcake/
├── overview/
├── architecture/
├── getting-started/
├── use-cases/
├── examples/
├── nuances/
└── tool-guides/`;
---

<Base
	title="ContextCake Packs - structured context packs"
	description="Browse ContextCake Packs: structured, inspectable knowledge bundles built as OKF-compatible markdown for real team workflows."
>
	<main class="packs-index">
		<section class="hero" aria-labelledby="packs-title">
			<div class="hero-copy">
				<p class="eyebrow">ContextCake Packs</p>
				<h1 id="packs-title">Ready-made files for teams that already use AI at work.</h1>
				<p class="lede">
					Each pack bundles the files a team keeps recreating in chat: rules, workflows,
					templates, examples, and editor guidance. You can inspect the structure, keep local
					edits separate, and reuse the same material across tools.
				</p>
				<ul class="hero-points" aria-label="Pack benefits">
					{heroPoints.map((item) => <li>{item}</li>)}
				</ul>
				<div class="hero-actions">
					<a class="view-link hero-link" href={featuredPack.href}>Read it free</a>
					<a class="view-link hero-link hero-link-secondary" href="#structure">See the file layout</a>
				</div>
			</div>
			<aside class="hero-panel" aria-label="How packs are structured">
				<p class="panel-label">Open knowledge format</p>
				<p>
					Pack content uses OKF-compatible markdown where that shape helps. The practical
					bit: the files stay inspectable, referenceable, and easy to layer with local team
					edits.
				</p>
				<a href="/docs/concepts/okf-bundles">Read the OKF bundle shape</a>
			</aside>
		</section>

		<section class="catalog" aria-labelledby="catalog-title">
			<div class="section-head">
				<p class="eyebrow">Available pack</p>
				<h2 id="catalog-title">Current pack</h2>
			</div>

			<article class="pack-card">
				<div class="pack-mark" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</div>
				<div class="pack-copy">
					<p class="status">{featuredPack.status}</p>
					<h3>{featuredPack.name}</h3>
					<p>{featuredPack.summary}</p>
					<p class="best-for"><strong>Best for:</strong> {featuredPack.bestFor}</p>
					<ul class="benefit-list" aria-label={`${featuredPack.name} benefits`}>
						{featuredPack.benefits.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="pack-meta">
					<div>
						<p class="meta-label">Includes</p>
						<ul>
							{featuredPack.includes.map((item) => <li>{item}</li>)}
						</ul>
					</div>
					<div>
						<p class="meta-label">Formats</p>
						<ul>
							{featuredPack.formats.map((format) => <li>{format}</li>)}
						</ul>
					</div>
					<a class="view-link" href={featuredPack.href}>Read the pack</a>
				</div>
			</article>
		</section>

		<section class="structure" aria-labelledby="structure-title">
			<div class="section-head compact">
				<p class="eyebrow">Pack contract</p>
				<h2 id="structure-title">Same layout every time.</h2>
				<p>
					The pack shape is part of the product. A person can scan it quickly, and an AI tool
					can navigate it without guessing.
				</p>
			</div>
			<div class="structure-layout">
				<div class="structure-preview">
					<CodeBlock className="tree-preview" lang="text" code={structurePreview} />
				</div>
				<div class="structure-grid">
					{packSections.map(([name, body]) => (
						<article>
							<h3>{name}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	</main>
</Base>

<style>
	.packs-index {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 2rem;
	}
	.hero,
	.pack-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 22rem);
		gap: 1.5rem;
		align-items: start;
	}
	.hero {
		padding: 0.75rem 0 2.5rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.eyebrow,
	.status,
	.panel-label,
	.meta-label {
		margin: 0 0 0.75rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	h1,
	h2,
	h3,
	p {
		letter-spacing: 0;
	}
	h1 {
		max-width: 11ch;
		margin: 0;
		font-size: clamp(2.15rem, 3.3vw, 3.5rem);
		line-height: 0.97;
	}
	.lede,
	.hero-panel p,
	.pack-copy p,
	.section-head > p:last-child,
	.structure-grid p {
		color: var(--cc-text-body);
		line-height: 1.62;
	}
	.lede {
		max-width: 60ch;
		margin: 1rem 0 0;
		font-size: 1.1rem;
	}
	.hero-points,
	.benefit-list,
	.pack-meta ul {
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
	}
	.hero-points,
	.benefit-list {
		display: grid;
		gap: 0.55rem;
	}
	.hero-points li,
	.benefit-list li,
	.pack-meta li {
		color: var(--cc-text-body);
	}
	.hero-points li::before,
	.benefit-list li::before,
	.pack-meta li::before {
		content: '';
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		margin-right: 0.55rem;
		border-radius: 2px;
		background: var(--cc-layer-personal);
		vertical-align: 0.08em;
	}
	.hero-panel,
	.pack-meta {
		padding: 1rem 1.05rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: var(--cc-surface);
		box-shadow: var(--cc-shadow-panel);
	}
	.hero-panel a,
	.view-link {
		color: var(--cc-text);
		font-weight: 700;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.24em;
	}
	.catalog,
	.structure {
		padding: 2.5rem 0 0;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.25rem;
	}
	.section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.5rem;
	}
	.section-head.compact {
		align-items: start;
	}
	.section-head .eyebrow {
		grid-column: 1 / -1;
		margin-bottom: -0.25rem;
	}
	.section-head h2 {
		max-width: 11ch;
		margin: 0;
		font-size: clamp(1.55rem, 2.2vw, 2.25rem);
		line-height: 1.03;
	}
	.section-head > p:last-child {
		margin: 0;
		font-size: 1rem;
	}
	.pack-card {
		grid-template-columns: auto minmax(0, 1fr) minmax(15rem, 18rem);
		padding: 1.1rem 0 1.25rem;
		border-top: 1px solid var(--cc-border);
		border-bottom: 1px solid var(--cc-border);
	}
	.pack-mark {
		display: grid;
		gap: 0.35rem;
		width: 4.25rem;
		padding-top: 0.3rem;
	}
	.pack-mark span {
		display: block;
		height: 0.82rem;
		border-radius: 4px;
	}
	.pack-mark span:nth-child(1) {
		margin-left: 0.85rem;
		background: var(--cc-layer-personal);
	}
	.pack-mark span:nth-child(2) {
		background: var(--cc-layer-team);
	}
	.pack-mark span:nth-child(3) {
		margin-left: 0.4rem;
		background: var(--cc-layer-company);
	}
	.pack-copy h3 {
		margin: 0;
		font-size: clamp(1.6rem, 3vw, 2.5rem);
		line-height: 1;
	}
	.pack-copy p {
		max-width: 56ch;
		margin: 0.75rem 0 0;
		font-size: 1rem;
	}
	.best-for {
		margin-top: 0.9rem;
	}
	.meta-label {
		color: var(--cc-layer-personal);
	}
	.view-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		margin-top: 1.2rem;
		padding: 0 1rem;
		border: 1px solid var(--cc-cta);
		border-radius: 6px;
		background: var(--cc-cta);
		color: var(--cc-on-cta);
		text-decoration: none;
	}
	.hero-link {
		margin-top: 0;
	}
	.hero-link-secondary {
		border-color: var(--cc-border);
		background: transparent;
		color: var(--cc-text);
	}
	.structure-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem;
	}
	.structure-layout {
		display: grid;
		grid-template-columns: minmax(17rem, 22rem) minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
	}
	.structure-preview :global(.tree-preview .shiki) {
		font-size: 0.92rem;
		line-height: 1.55;
	}
	.structure-grid article {
		padding: 1rem 0 1rem 1rem;
		border-left: 2px solid color-mix(in srgb, var(--cc-layer-team) 40%, var(--cc-border));
	}
	.structure-grid h3 {
		margin: 0 0 0.65rem;
		color: var(--cc-text);
		font-family: var(--cc-font-mono);
		font-size: 0.92rem;
	}
	.structure-grid p {
		margin: 0;
		font-size: 0.97rem;
	}
	@media (max-width: 920px) {
		.hero,
		.section-head,
		.pack-card {
			grid-template-columns: 1fr;
		}
		.structure-layout {
			grid-template-columns: 1fr;
		}
		.section-head .eyebrow {
			margin-bottom: 0;
		}
		.structure-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 620px) {
		.packs-index {
			padding-top: 2rem;
		}
		.pack-card {
			grid-template-columns: 1fr;
		}
		.structure-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
