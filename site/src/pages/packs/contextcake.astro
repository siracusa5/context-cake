---
import { fileURLToPath } from 'node:url';
import PackExplorer from '../../components/PackExplorer.astro';
import Base from '../../layouts/Base.astro';
import { loadPackExplorer } from '../../lib/pack-explorer';

const packRoot = fileURLToPath(
	new URL('../../../../specs/contextcake-packs/packs/contextcake', import.meta.url),
);
const explorer = await loadPackExplorer(packRoot, 'contextcake');
const fileCount = explorer.files.length;
const folderCount = explorer.treeEntries.filter((entry) => entry.kind === 'dir').length;

// Checkout infrastructure is kept but dormant — live payments are deferred while the pack
// ships as a free preview. To start selling: fill these links and set paymentsLive = true.
const LEMONSQUEEZY_BASE_PACK_URL = 'https://STORE.lemonsqueezy.com/buy/REPLACE_BASE_PACK';
const paymentsLive = false;

const fitRows = [
	['Good fit', 'Developers — and their AI agents — adopting or building on ContextCake.'],
	['Not for', 'Readers who just want the marketing overview; the rest of the site covers that.'],
	['Delivery', 'Plain markdown files first, with Claude Code plugin packaging.'],
];

const valuePoints = [
	'What ContextCake is and the mental model',
	'Architecture: sources, resolver, merge, conflicts',
	'Install, first cascade, and writing a layer',
	'MCP tools and connecting an AI agent',
];

const quickFacts = [
	['Files', `${fileCount} source files`],
	['Folders', `${folderCount} directories`],
	['Format', 'Markdown first'],
	['Accuracy', 'Current model only'],
];

const featuredFiles = [
	{ label: 'Start here', path: 'START-HERE.md' },
	{ label: 'What it is', path: 'overview/what-is-contextcake.md' },
	{ label: 'Layers', path: 'architecture/layers-and-precedence.md' },
	{ label: 'Install', path: 'getting-started/installation.md' },
];

const workflowSteps = [
	['01', 'Understand', 'What ContextCake is, the layer cake, and how higher layers win per section — the mental model in a few files.'],
	['02', 'Install', 'Get the dependency-free engine running on Node 18+ and resolve your first cascade.'],
	['03', 'Write a layer', 'Author OKF concepts — frontmatter plus anchored sections — that team and personal layers can override.'],
	['04', 'Connect an agent', 'Run the MCP server and point Claude, Cursor, or any MCP client at the resolved graph.'],
];

const insideRows = [
	['Understand the architecture fast', 'Federated storage, the resolver, section merge, and provenance — explained for someone adopting it, not just skimming marketing.'],
	['Get an agent productive', 'Tool guides plus an MCP walkthrough so Claude, Cursor, or Copilot can use ContextCake in your repo from real context.'],
	['Copy real examples', 'A full OKF concept, a working layers.json, and a resolved read_file payload with surfaced conflicts.'],
	['Avoid the sharp edges', 'The nuances that bite: precedence and recency, the manifest trust boundary, conflicts-not-hidden, the dependency-free rule.'],
];

const useCases = [
	['Adopting ContextCake', 'Wiring ContextCake into a repo and wanting your agent to actually know how it works.'],
	['Onboarding a teammate', 'Someone new needs the architecture and conventions without reading the whole codebase.'],
	['Building on the engine', 'Extending sources, the resolver, or the MCP server, and needing the model precise.'],
	['Explaining it to an AI tool', 'ChatGPT, Cursor, or Copilot should answer ContextCake questions accurately, not from stale guesses.'],
];

const compatRows = [
	['Plain files', 'Markdown you can open, read, and edit anywhere. This is the baseline — no tool required.'],
	['Claude Code', 'Install as a plugin, or point Claude at the unzipped files.'],
	['ChatGPT', 'Upload the files as project or knowledge files, then reference them in prompts.'],
	['Cursor & Copilot', 'Keep the files in your repo so the assistant reads them as working context.'],
];

const faqs = [
	{
		q: 'Is this just the ContextCake docs?',
		a: 'It overlaps, but it is packaged as portable context files an AI agent can pull into your project — not a website to browse. Same facts, agent-ready.',
	},
	{
		q: 'Do I need this to use ContextCake?',
		a: 'No. The engine is free and dependency-free. This pack gives your assistant the full, accurate context so it can help you wire ContextCake in faster.',
	},
	{
		q: 'Is it accurate to the current version?',
		a: 'Yes — it is distilled from the current design spec and docs, and it drops the superseded bits (no shadow-drift subsystem, no Group layer).',
	},
	{
		q: 'What becomes paid later?',
		a: 'The base pack stays free. Curated updates and additional packs are the future paid tiers.',
	},
];
---

<Base
	title="ContextCake Context Pack"
	description="A portable, agent-ready context pack about ContextCake itself — architecture, OKF, the resolver, MCP tools, install, and the sharp edges — so your AI assistant can actually help you use it."
>
	<main class="pack-page">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">ContextCake Pack</p>
				<h1 id="hero-title">Everything your agent needs to use ContextCake.</h1>
				<p class="lede">
					Drop this pack into your project so your AI assistant understands ContextCake —
					the architecture, the OKF format, the resolver, the MCP tools — and can actually
					help you wire it in, instead of guessing.
				</p>
				<div class="hero-actions" aria-label="Primary actions">
					<a class="button primary" href="#explorer">Read the pack free</a>
					<a class="button" href="#pricing">What’s coming</a>
				</div>
				<dl class="quick-facts" aria-label="Pack quick facts">
					{quickFacts.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
				<ul class="value-list" aria-label="What the pack includes">
					{valuePoints.map((item) => <li>{item}</li>)}
				</ul>
			</div>

			<aside class="summary-panel" aria-label="Pack fit summary">
				<p class="panel-label">At a glance</p>
				<dl class="fit-list">
					{fitRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</aside>
		</section>

		<section class="workflow" aria-labelledby="workflow-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">The arc</p>
					<h2 id="workflow-title">From zero to connected.</h2>
				</div>
				<p>
					The pack is ordered the way you actually adopt ContextCake — understand it, run
					it, author for it, then hand it to your agent.
				</p>
			</div>
			<ol class="workflow-grid" aria-label="The adoption arc">
				{workflowSteps.map(([num, title, body]) => (
					<li class="step">
						<span class="step-num" aria-hidden="true">{num}</span>
						<h3>{title}</h3>
						<p>{body}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="explorer" class="explorer-section" aria-labelledby="explorer-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Look inside</p>
					<h2 id="explorer-title">Open the pack.</h2>
				</div>
				<p>
					File tree on the left, rendered markdown on the right — toggle to source any time.
					Start with the featured files for the quick read.
				</p>
			</div>
			<PackExplorer
				id="contextcake-pack-explorer"
				explorer={explorer}
				featuredFiles={featuredFiles}
				defaultFile="START-HERE.md"
				title="ContextCake pack explorer"
			/>
		</section>

		<section class="detail-band" aria-labelledby="pack-uses-title">
			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">Use it for</p>
						<h2 id="pack-uses-title">When it earns its place.</h2>
					</div>
				</div>
				<div class="case-grid">
					{useCases.map(([title, body]) => (
						<article>
							<h3>{title}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</div>

			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">What’s inside</p>
						<h2 id="inside-title">What you get out of it.</h2>
					</div>
				</div>
				<dl class="inside-list">
					{insideRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<section id="pricing" class="pricing" aria-labelledby="pricing-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">{paymentsLive ? 'Pricing' : 'Early access'}</p>
					<h2 id="pricing-title">{paymentsLive ? 'Buy once. Update if you want.' : 'Free while it’s in preview.'}</h2>
				</div>
				<p>
					{paymentsLive
						? 'The base pack is a one-time purchase you keep. Updates are a separate, optional monthly subscription.'
						: 'The full pack is free to read right now. Curated updates and more packs are on the way as paid add-ons — this pack stays free.'}
				</p>
			</div>

			<div class="plan-grid">
				<article class="plan plan-primary">
					<p class="card-label">The pack</p>
					<p class="price">
						<span class="price-amount">Free</span>
						<span class="price-suffix">in preview</span>
					</p>
					<p class="cadence">Read the whole thing, no signup.</p>
					<h3>ContextCake Context Pack</h3>
					<p class="plan-body">The full pack — overview, architecture, getting-started, use cases, examples, and nuances — free to read right now. Open the explorer above.</p>
					<a class="button primary" href="#explorer">Read the full pack</a>
				</article>
				<article class="plan">
					<p class="card-label">Coming soon</p>
					<p class="price">
						<span class="price-amount">More</span>
						<span class="price-suffix">packs, later</span>
					</p>
					<p class="cadence">Curated updates and additional profession packs.</p>
					<h3>Updates and more packs</h3>
					<p class="plan-body">When paid tiers open, this pack stays free. You’d only pay for ongoing curated updates and additional packs.</p>
					<span class="button coming-soon" aria-disabled="true">Coming soon</span>
				</article>
			</div>

			{!paymentsLive && (
				<p class="pricing-note">
					No checkout yet — the pack is free to read while it’s in preview. Paid updates and
					more packs are coming.
				</p>
			)}
		</section>

		<section class="compatibility" aria-labelledby="compat-title">
			<div class="section-head compact-head">
				<div>
					<p class="eyebrow">Works with your tools</p>
					<h2 id="compat-title">Plain files first. Everything else is a bonus.</h2>
				</div>
			</div>
			<dl class="compat-grid">
				{compatRows.map(([term, body]) => (
					<div>
						<dt>{term}</dt>
						<dd>{body}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="faq" aria-labelledby="faq-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 id="faq-title">Before you ask.</h2>
				</div>
			</div>
			<div class="faq-list">
				{faqs.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section class="credibility" aria-label="About ContextCake">
			<p>
				The ContextCake context pack is made by <strong>ContextCake</strong>, the context
				layer that keeps team knowledge consistent across AI tools.
			</p>
			<a class="view-link" href="/">Learn about ContextCake</a>
		</section>
	</main>
</Base>

<style>
	.pack-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 2rem;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 23rem);
		gap: 1.2rem;
		align-items: start;
		padding: 0.75rem 0 2rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.eyebrow,
	.panel-label,
	.card-label {
		margin: 0 0 0.75rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	h1, h2, h3, p { letter-spacing: 0; }
	h1 {
		max-width: 14ch;
		margin: 0;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 0.98;
	}
	.lede,
	.section-head > p:last-child,
	.fit-list dd,
	.case-grid p,
	.inside-list dd,
	.plan-body,
	.compat-grid dd,
	.faq p {
		color: var(--cc-text-body);
		line-height: 1.62;
	}
	.lede {
		max-width: 58ch;
		margin: 0.95rem 0 0;
		font-size: 1.08rem;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.25rem;
	}
	.quick-facts {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
		margin: 1rem 0 0;
	}
	.quick-facts div {
		padding: 0.8rem 0.85rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.quick-facts dt {
		margin: 0;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.quick-facts dd {
		margin: 0.35rem 0 0;
		color: var(--cc-text);
		font-size: 0.94rem;
		font-weight: 700;
		line-height: 1.35;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 6px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration: none;
	}
	.button.primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.button.coming-soon {
		border-style: dashed;
		color: var(--cc-text-body);
		opacity: 0.7;
		cursor: default;
	}
	.value-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem 1rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
		max-width: 48rem;
	}
	.value-list li { color: var(--cc-text-body); }
	.value-list li::before {
		content: '';
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		margin-right: 0.55rem;
		border-radius: 2px;
		background: var(--cc-layer-personal);
		vertical-align: 0.08em;
	}
	.summary-panel {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 82%, transparent);
		box-shadow: var(--cc-shadow-panel);
	}
	.fit-list { display: grid; gap: 0.85rem; margin: 0; }
	.fit-list div { display: grid; gap: 0.18rem; }
	.fit-list dt { color: var(--cc-text); font-weight: 700; }
	.fit-list dd { margin: 0; font-size: 0.98rem; }
	.workflow,
	.explorer-section,
	.detail-band,
	.pricing,
	.compatibility,
	.faq {
		padding: 2.25rem 0 0;
	}
	.section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.88fr);
		gap: 1.4rem;
		align-items: end;
		margin-bottom: 1.25rem;
	}
	.section-head h2 {
		max-width: 16ch;
		margin: 0;
		font-size: clamp(1.45rem, 2vw, 2.05rem);
		line-height: 1.04;
	}
	.section-head > p:last-child { margin: 0; font-size: 1rem; }
	.compact-head { margin-bottom: 1rem; }
	.compact-head .section-head > p:last-child { display: none; }
	.workflow-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.9rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.step {
		padding: 1.1rem 1rem 1.2rem;
		border: 1px solid var(--cc-border);
		border-top: 4px solid var(--cc-layer-team);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
	}
	.workflow-grid li:nth-child(2) { border-top-color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(2) .step-num { color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(3) { border-top-color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(3) .step-num { color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(4) { border-top-color: var(--cc-cta); }
	.workflow-grid li:nth-child(4) .step-num { color: var(--cc-cta); }
	.step-num {
		display: block;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.92rem;
		font-weight: 700;
	}
	.step h3 { margin: 0.5rem 0 0; color: var(--cc-text); font-size: 1.12rem; }
	.step p { margin: 0.5rem 0 0; font-size: 0.95rem; }
	.detail-band {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.1rem;
		align-items: start;
	}
	.detail-column { min-width: 0; }
	.case-grid { display: grid; gap: 0.9rem; grid-template-columns: 1fr; }
	.case-grid article {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
		border-top: 4px solid var(--cc-layer-team);
	}
	.case-grid article:nth-child(2) { border-top-color: var(--cc-layer-company); }
	.case-grid article:nth-child(3) { border-top-color: var(--cc-layer-personal); }
	.case-grid article:nth-child(4) { border-top-color: var(--cc-cta); }
	.case-grid h3 { margin: 0; color: var(--cc-text); font-size: 1.12rem; }
	.case-grid p { margin: 0.55rem 0 0; font-size: 0.98rem; }
	.inside-list { display: grid; gap: 0.85rem; margin: 0; }
	.inside-list div {
		display: grid;
		gap: 0.2rem;
		padding: 0 0 0.85rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.inside-list div:last-child { padding-bottom: 0; border-bottom: 0; }
	.inside-list dt { color: var(--cc-text); font-weight: 700; }
	.inside-list dd { margin: 0; font-size: 0.98rem; }
	.plan-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.plan {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.2rem 1.35rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 74%, transparent);
	}
	.plan-primary {
		border-color: color-mix(in srgb, var(--cc-cta) 55%, var(--cc-border));
		box-shadow: var(--cc-shadow-panel);
	}
	.price {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
		margin: 0.2rem 0 0;
	}
	.price-amount { color: var(--cc-text); font-size: 2rem; font-weight: 700; line-height: 1; }
	.price-suffix {
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0;
	}
	.cadence { margin: 0.4rem 0 0; color: var(--cc-text-body); font-size: 0.9rem; }
	.plan h3 { margin: 0.75rem 0 0; color: var(--cc-text); font-size: 1.1rem; }
	.plan-body { margin: 0.5rem 0 0; font-size: 0.98rem; }
	.plan .button { margin-top: 1.1rem; width: fit-content; }
	.pricing-note { margin: 1rem 0 0; color: var(--cc-text-body); font-size: 0.94rem; }
	.compat-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem 1.1rem;
		margin: 0;
	}
	.compat-grid div {
		display: grid;
		gap: 0.2rem;
		padding: 0.9rem 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.compat-grid dt { color: var(--cc-text); font-weight: 700; }
	.compat-grid dd { margin: 0; font-size: 0.96rem; }
	.faq-list { display: grid; gap: 0.6rem; }
	details { padding: 1rem 0; border-top: 1px solid var(--cc-border); }
	summary { color: var(--cc-text); cursor: pointer; font-weight: 700; }
	.credibility {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem 1.5rem;
		margin-top: 2.5rem;
		padding: 1.25rem 0 0;
		border-top: 1px solid var(--cc-border);
	}
	.credibility p {
		max-width: 52ch;
		margin: 0;
		color: var(--cc-text-body);
		line-height: 1.55;
	}
	.credibility strong { color: var(--cc-text); }
	.view-link {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.24em;
	}
	@media (max-width: 920px) {
		.hero, .section-head, .detail-band { grid-template-columns: 1fr; }
		.workflow-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.quick-facts { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	}
	@media (max-width: 620px) {
		.pack-page { padding-top: 2rem; }
		.workflow-grid, .plan-grid, .compat-grid, .quick-facts { grid-template-columns: 1fr; }
		.value-list { grid-template-columns: 1fr; }
	}
</style>
