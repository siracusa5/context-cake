---
// Changelog — generated from GitHub releases at build time (design.md §6).
// Unauthenticated fetch only, no secrets in the build. While the repo is
// private the API returns 404 and the page degrades to a graceful empty state;
// any network/parse failure does the same, so the build never breaks on it.
import Base from '../layouts/Base.astro';

async function loadReleases() {
	try {
		const res = await fetch(
			'https://api.github.com/repos/siracusa5/context-cake/releases',
			{
				headers: {
					Accept: 'application/vnd.github+json',
					'User-Agent': 'contextcake-site',
				},
				signal: AbortSignal.timeout(5000),
			},
		);
		if (!res.ok) return [];
		const data = await res.json();
		if (!Array.isArray(data)) return [];
		return data
			.filter((r) => !r.draft)
			.map((r) => ({
				name: r.name || r.tag_name,
				tag: r.tag_name,
				date: r.published_at ? r.published_at.slice(0, 10) : null,
				url: r.html_url,
				body: (r.body || '').trim(),
			}));
	} catch {
		return [];
	}
}

const releases = await loadReleases();
---

<Base
	title="ContextCake changelog"
	description="Release notes for ContextCake, generated from GitHub releases."
>
	<main class="changelog">
		<p class="kicker">Changelog</p>
		<h1>Releases</h1>

		{
			releases.length === 0 ? (
				<div class="empty">
					<p>No releases yet.</p>
					<p class="muted">
						ContextCake is <a href="/install">clone-and-run</a> today. Tagged releases —
						with provenance attestation when a package channel ships — will appear here,
						pulled from{' '}
						<a href="https://github.com/siracusa5/context-cake/releases">GitHub Releases</a>{' '}
						at build time.
					</p>
				</div>
			) : (
				<ol class="releases">
					{releases.map((r) => (
						<li class="release">
							<div class="release-head">
								<h2>{r.name}</h2>
								{r.date && <time datetime={r.date}>{r.date}</time>}
							</div>
							<a class="tag" href={r.url}>
								{r.tag}
							</a>
							{r.body && (
								<div class="body">
									{r.body.split(/\n{2,}/).map((para) => (
										<p>{para}</p>
									))}
								</div>
							)}
						</li>
					))}
				</ol>
			)
		}
	</main>
</Base>

<style>
	.changelog {
		max-width: 46rem;
		margin: 0 auto;
		padding: 3rem 1.5rem;
	}
	.kicker {
		font-family: var(--cc-font-heading);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		color: var(--cc-text-muted);
		margin: 0 0 0.5rem;
	}
	h1 {
		margin: 0 0 2rem;
	}
	.empty {
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: 12px;
		padding: 2rem;
	}
	.empty p {
		margin: 0 0 0.75rem;
	}
	.empty p:last-child {
		margin-bottom: 0;
	}
	.muted {
		color: var(--cc-text-muted);
		font-size: 0.95rem;
	}
	.empty a,
	.body a {
		color: var(--cc-layer-team);
	}
	.releases {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}
	.release {
		padding: 2rem 0;
		border-top: 1px solid var(--cc-border);
	}
	.release:first-child {
		padding-top: 0;
		border-top: 0;
	}
	.release-head {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem;
	}
	.release-head h2 {
		margin: 0;
		font-size: 1.25rem;
	}
	.release-head time {
		font-family: var(--cc-font-mono);
		font-size: 0.85rem;
		color: var(--cc-text-muted);
	}
	.tag {
		display: inline-block;
		font-family: var(--cc-font-mono);
		font-size: 0.75rem;
		color: var(--cc-layer-team);
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		padding: 0.15rem 0.6rem;
		margin: 0.5rem 0 0.85rem;
		text-decoration: none;
	}
	.tag:hover {
		border-color: var(--cc-layer-team);
	}
	.body {
		color: var(--cc-text-body);
	}
	.body p {
		margin: 0 0 0.75rem;
	}
</style>
