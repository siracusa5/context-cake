{
  "name": "contextcake-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build-demo-data": "node scripts/build-demo-data.mjs",
    "predev": "npm run build-demo-data",
    "dev": "vite",
    "prebuild": "npm run build-demo-data",
    "build": "tsc -b && vite build",
    "prebuild:live": "npm run build-demo-data",
    "build:live": "tsc -b && vite build --base=/console/",
    "preview": "vite preview",
    "pretypecheck": "npm run build-demo-data",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build-demo-data",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
