{
  "name": "contextcake-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build-demo-data": "node scripts/build-demo-data.mjs",
    "predev": "npm run build-demo-data",
    "dev": "vite",
    "prebuild": "npm run build-demo-data",
    "build": "tsc -b && vite build",
    "prebuild:live": "npm run build-demo-data",
    "build:live": "tsc -b && vite build --base=/console/",
    "preview": "vite preview",
    "pretypecheck": "npm run build-demo-data",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build-demo-data",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/bricolage-grotesque": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
