---
// Homepage resolver-backed product story. Every merge value shown here is
// generated from the real demo cascade during the site build.
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import demo from '../data/demo-cascade.json';
import appIconUrl from '../../../../assets/brand/contextcake-app-icon.svg?url';

const primaryDb = demo.concepts.find((concept) => concept.id === 'decisions/primary-db');
if (!primaryDb) throw new Error('Homepage demo concept decisions/primary-db is missing');

const bodySections = primaryDb.sections.filter(
	(section) => !section.suppressed && section.content.trim() !== '',
);
const byKey = Object.fromEntries(bodySections.map((section) => [section.key, section]));
const heroContributors = primaryDb.contributors;
const conceptTitle = primaryDb.frontmatter?.title ?? 'decisions/primary-db';

const layerShort = { personal: 'You', team: 'Team', company: 'Company' };
const layerColor = {
	personal: 'var(--cc-layer-personal)',
	team: 'var(--cc-layer-team)',
	company: 'var(--cc-layer-company)',
};
const sectionLabel = {
	choice: 'Which database',
	rationale: 'Why this choice',
	analytics: 'Analytics store',
	ownership: 'Who owns it',
};
const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const shortDate = (iso) => {
	const [, month, day] = iso.split('-').map(Number);
	return `${MONTHS[month - 1]} ${day}`;
};
const clean = (value, limit = 88) => {
	const oneLine = value.replace(/\s+/g, ' ').trim();
	return oneLine.length > limit ? `${oneLine.slice(0, limit).trimEnd()}…` : oneLine;
};

const storyBands = ['choice', 'rationale', 'analytics', 'ownership']
	.map((key) => byKey[key])
	.filter(Boolean)
	.map((section) => ({
		label: sectionLabel[section.key] ?? section.key,
		summary: clean(section.content),
		layer: section.sourceLayer,
		updated: section.sourceUpdated,
		conflict: section.conflicts?.[0] ?? null,
	}));

const choiceConflict = byKey.choice?.conflicts?.[0] ?? null;
const appDownloadUrl = 'https://github.com/ContextCake/context-cake/releases/download/app-v0.1.0/ContextCake-0.1.0-arm64.dmg';
const sourceDownloadUrl = 'https://github.com/ContextCake/context-cake/archive/refs/tags/console-v0.2.0.tar.gz';

const principles = [
	{
		number: '01',
		title: 'Closer context wins only where it speaks.',
		body: 'Your note can override one section without replacing the rest of the company decision. ContextCake resolves the concept section by section.',
		layer: 'personal',
	},
	{
		number: '02',
		title: 'Silence inherits.',
		body: 'When a closer layer says nothing, the answer falls through to the next source. Useful context survives instead of being copied into one master file.',
		layer: 'team',
	},
	{
		number: '03',
		title: 'Dissent stays attached.',
		body: 'The losing value is not deleted. Its source, date, and text travel with the answer so an agent can act with the disagreement in view.',
		layer: 'company',
	},
];

const capabilities = [
	{
		icon: 'tag',
		title: 'Provenance on every section',
		body: 'Every field says which layer supplied it and when that source changed.',
	},
	{
		icon: 'compare',
		title: 'Conflicts with dates',
		body: 'Contradictions remain readable beside the effective answer, not buried in history.',
	},
	{
		icon: 'share',
		title: 'Local files and foreign graphs',
		body: 'Mix OKF-compatible markdown with trusted MCP sources in the same cascade.',
	},
	{
		icon: 'branch',
		title: 'A write path from real work',
		body: 'Capture useful signals, draft concepts, and route sensitive changes through review.',
	},
	{
		icon: 'send',
		title: 'Made for agent clients',
		body: 'Search, read, list, and traverse the resolved graph through a small MCP surface.',
	},
	{
		icon: 'shield',
		title: 'An inspectable core',
		body: 'Plain Node.js, zero runtime dependencies, and no postinstall supply-chain surprise.',
	},
];

const mcpTools = ['search', 'read_file', 'list_concepts', 'get_links'];
---

<Base
	tone="dark"
	title="ContextCake | working context for AI teams"
	description="Resolve company policy, team practice, and local judgment into one sourced answer for every AI agent."
>
	<main class="home">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow"><span>ContextCake</span> · context that keeps its receipts</p>
				<h1 id="hero-title">All your sources,<br /><em>one answer</em></h1>
				<p class="hero-lede">
					Your agent should not have to guess whether the wiki, the runbook, or your notes are
					current. ContextCake resolves them into one answer. Every section keeps its source,
					date, and disagreement.
				</p>
				<div class="hero-actions" aria-label="Get started">
					<a class="button button--primary button--download" href={appDownloadUrl} download>
						<Icon name="download" size={18} />
						Download the Mac app
					</a>
					<a class="text-link" href={sourceDownloadUrl} download>Download the source archive</a>
					<a class="button button--quiet" href="/demo">Open the live demo</a>
					<a class="text-link" href="/docs">Read the docs</a>
				</div>
				<div class="download-meta" aria-label="Download details">
					<span><i aria-hidden="true"></i>Signed + notarized</span>
					<span>macOS · Apple silicon</span>
					<span>DMG · 0.1.0</span>
				</div>
			</div>

			<figure class="app-window app-window--hero" aria-label="ContextCake Console showing a resolved concept">
				<div class="window-bar">
					<div class="window-brand">
						<img src={appIconUrl} alt="" width="28" height="28" />
						<span>ContextCake</span>
					</div>
					<div class="window-dots" aria-hidden="true"><span></span><span></span><span></span></div>
				</div>
				<div class="window-body">
					<nav aria-label="Console preview navigation">
						<p>Context console</p>
						<a href="/demo"><Icon name="dashboard" size={17} /> Overview</a>
						<a href="/demo"><Icon name="compare" size={17} /> Conflicts <span>2</span></a>
						<a href="/demo"><Icon name="branch" size={17} /> Concepts</a>
					</nav>
					<div class="window-content">
						<header>
							<div><p>Resolved concept</p><h2>{conceptTitle}</h2></div>
							<span class="window-status"><i></i> 3 layers</span>
						</header>
						<div class="window-layers">
							{heroContributors.map((source) => (
								<div style={`--layer: ${layerColor[source.layer]}`}>
									<span></span><strong>{layerShort[source.layer]}</strong><small>{shortDate(source.updated)}</small>
								</div>
							))}
						</div>
						<div class="window-answer">
							{storyBands.map((band) => (
								<div style={`--layer: ${layerColor[band.layer]}`}>
									<span></span><strong>{band.label}</strong><small>{layerShort[band.layer]}</small>
								</div>
							))}
						</div>
						{choiceConflict && (
							<div class="window-conflict">
								<Icon name="alert" size={14} />
								<span>Company policy disagrees with the effective answer</span>
							</div>
						)}
					</div>
				</div>
				<figcaption>ContextCake Console · resolved concept with sources and conflicts intact</figcaption>
			</figure>
		</section>

		<section class="thesis" aria-labelledby="thesis-title">
			<p class="section-number">01 / The idea</p>
			<h2 id="thesis-title">Context is not one document.<br />It is a set of claims with scope.</h2>
			<p>
				Company policy, team practice, and local judgment can all be true at once. ContextCake
				turns that structure into something an agent can read without flattening the nuance.
			</p>
		</section>

		<section class="mechanic" aria-labelledby="mechanic-title">
			<div class="section-heading">
				<p class="section-number">02 / The resolver</p>
				<h2 id="mechanic-title">A simple rule.<br />A more honest answer.</h2>
			</div>
			<ol class="principles">
				{principles.map((principle) => (
					<li style={`--layer: ${layerColor[principle.layer]}`}>
						<span class="principle-number">{principle.number}</span>
						<div class="principle-copy">
							<h3>{principle.title}</h3>
							<p>{principle.body}</p>
						</div>
						<div class="principle-mark" aria-hidden="true"><span></span><span></span><span></span></div>
					</li>
				))}
			</ol>
		</section>

		<section class="product-stage" aria-labelledby="product-title">
			<div class="product-copy">
				<div>
					<p class="section-number">03 / One engine, every surface</p>
					<h2 id="product-title">Inspect it in the app.<br />Serve it to every agent.</h2>
				</div>
				<div class="product-detail">
					<p>
						ContextCake is a local product, not another knowledge silo. The Mac app gives the
						resolver a clear visual surface. MCP gives the same sourced answer to Claude, Codex,
						Cursor, and any compatible client.
					</p>
					<div class="product-links">
						<a class="button button--light" href="/demo">Explore the console</a>
						<a class="stage-link" href="/docs/getting-started/connect-an-agent">Connect an agent →</a>
					</div>
					<div class="tool-line" aria-label="MCP tools">
						<span>MCP</span>
						{mcpTools.map((tool) => <code>{tool}</code>)}
					</div>
				</div>
			</div>
		</section>

		<section class="system" aria-labelledby="system-title">
			<div class="section-heading">
				<p class="section-number">04 / What ships with the answer</p>
				<h2 id="system-title">Enough structure to trust.<br />No machinery to worship.</h2>
			</div>
			<div class="capabilities">
				{capabilities.map((capability, index) => (
					<article>
						<div class="capability-index">0{index + 1}</div>
						<Icon name={capability.icon} size={20} />
						<h3>{capability.title}</h3>
						<p>{capability.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="closing" aria-labelledby="closing-title">
			<div>
				<p class="section-number">Start with the engine</p>
				<h2 id="closing-title">Give your agent<br />the whole story.</h2>
				<p>
					Download the signed Mac app for the zero-terminal path, or use the inspectable source
					archive when you want to run the engine directly.
				</p>
				<div class="closing-actions">
					<a class="button button--primary button--download" href={appDownloadUrl} download>
						<Icon name="download" size={18} />
						Download the Mac app
					</a>
					<a class="text-link" href={sourceDownloadUrl} download>Download the source archive →</a>
					<a class="text-link" href="/docs/getting-started/first-cascade">Build your first cascade →</a>
				</div>
			</div>
			<div class="closing-download">
				<p>Mac download · signed + notarized</p>
				<a class="download-file" href={appDownloadUrl} download>
					<span>
						<strong>ContextCake for Mac</strong>
						<small>app-v0.1.0 · Apple silicon · .dmg</small>
					</span>
					<Icon name="download" size={24} />
				</a>
				<span>Drag to Applications, then open. Source archive remains available on the install page.</span>
			</div>
		</section>
	</main>
</Base>

<style>
	.home {
		--home-ink: var(--cc-ink);
		--home-body: var(--cc-ink-body);
		--home-muted: var(--cc-ink-muted);
		position: relative;
		z-index: 0;
		overflow: hidden;
		color: var(--home-body);
	}
	:global(body.theme-dark) .home {
		--home-ink: var(--cc-text);
		--home-body: var(--cc-text-body);
		--home-muted: var(--cc-text-muted);
	}
	.home h1,
	.home h2,
	.home h3,
	.home p,
	.home figure {
		margin-top: 0;
	}
	.home figure {
		margin-inline: 0;
		margin-bottom: 0;
	}
	.hero,
	.mechanic,
	.system,
	.closing {
		max-width: 88rem;
		margin: 0 auto;
		padding-inline: clamp(1.25rem, 4vw, 4rem);
	}
	.eyebrow,
	.section-number {
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.eyebrow {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		color: var(--home-muted);
	}
	.eyebrow span {
		color: var(--home-ink);
	}
	.eyebrow::before {
		content: '';
		width: 2.5rem;
		height: 0.28rem;
		background: linear-gradient(90deg, var(--cc-layer-personal) 0 33%, var(--cc-layer-team) 33% 66%, var(--cc-layer-company) 66%);
	}
	.section-number {
		color: var(--home-muted);
	}

	/* Hero: large editorial promise next to the actual product surface. */
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(32rem, 1.08fr);
		gap: clamp(2.5rem, 5vw, 6rem);
		align-items: center;
		min-height: calc(100vh - 76px);
		padding-top: clamp(3.5rem, 7vw, 7rem);
		padding-bottom: clamp(4rem, 8vw, 7rem);
	}
	.hero-copy {
		min-width: 0;
	}
	.hero h1 {
		max-width: 12ch;
		margin-bottom: 1.6rem;
		font-size: clamp(3.6rem, 6.4vw, 7.35rem);
		font-weight: 600;
		letter-spacing: -0.065em;
		line-height: 0.88;
		text-wrap: balance;
	}
	.hero h1 em {
		color: var(--home-muted);
		font-style: normal;
		font-weight: 400;
	}
	.hero-lede {
		max-width: 38rem;
		margin-bottom: 1.75rem;
		font-size: clamp(1.05rem, 1.45vw, 1.3rem);
		line-height: 1.55;
	}
	.hero-actions,
	.product-links,
	.closing-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 0.7rem 1.15rem;
		border: 1px solid var(--cc-paper-line-strong);
		border-radius: 999px;
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
		transition: background var(--cc-transition), color var(--cc-transition), border-color var(--cc-transition);
	}
	.button--primary {
		background: var(--cc-ink);
		border-color: var(--cc-ink);
		color: var(--cc-paper) !important;
	}
	.button--primary:hover {
		background: var(--cc-ink-body);
	}
	.button--quiet:hover {
		background: var(--cc-paper-line);
	}
	.text-link,
	.stage-link {
		font-weight: 700;
		text-underline-offset: 0.25rem;
	}
	.hero-actions .text-link {
		padding: 0.7rem 0.25rem;
	}
	.button--download {
		gap: 0.5rem;
	}
	.download-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem 0.85rem;
		margin-top: 1.5rem;
		font-family: var(--cc-font-mono);
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--home-muted);
	}
	.download-meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
	}
	.download-meta i,
	.window-status i {
		width: 0.42rem;
		height: 0.42rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
	}

	/* Thesis break: the brand's point of view, not a generic benefit grid. */
	.thesis {
		padding: clamp(5.5rem, 11vw, 10rem) max(1.25rem, calc((100vw - 80rem) / 2));
		background: var(--cc-ink);
		color: var(--cc-paper);
	}
	.thesis .section-number {
		color: var(--cc-layer-team);
	}
	.thesis h2 {
		max-width: 15ch;
		margin-bottom: 2rem;
		font-size: clamp(3rem, 6.4vw, 7rem);
		font-weight: 500;
		letter-spacing: -0.055em;
		line-height: 0.96;
		color: var(--cc-paper);
	}
	:global(body.theme-paper) .thesis h2 {
		color: var(--cc-paper);
	}
	.thesis > p:last-child {
		max-width: 41rem;
		margin: 0 0 0 auto;
		font-size: clamp(1.15rem, 1.8vw, 1.5rem);
		line-height: 1.55;
		color: rgba(255, 253, 246, 0.78);
	}

	.mechanic,
	.system {
		display: grid;
		grid-template-columns: minmax(15rem, 0.72fr) minmax(0, 1.28fr);
		gap: clamp(3rem, 8vw, 8rem);
		padding-top: clamp(5rem, 10vw, 9rem);
		padding-bottom: clamp(5rem, 10vw, 9rem);
	}
	.section-heading h2 {
		max-width: 12ch;
		font-size: clamp(2.6rem, 4.5vw, 5rem);
		font-weight: 500;
		letter-spacing: -0.05em;
		line-height: 0.98;
	}
	.principles {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.principles li {
		display: grid;
		grid-template-columns: 3rem minmax(0, 1fr) 5rem;
		gap: 1.25rem;
		align-items: start;
		padding: 1.8rem 0;
		border-top: 1px solid var(--cc-paper-line-strong);
	}
	.principles li:last-child {
		border-bottom: 1px solid var(--cc-paper-line-strong);
	}
	.principle-number,
	.capability-index {
		font-family: var(--cc-font-mono);
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--home-body);
	}
	.principle-copy h3 {
		margin-bottom: 0.5rem;
		font-size: clamp(1.25rem, 2vw, 1.75rem);
		line-height: 1.15;
	}
	.principle-copy p {
		max-width: 38rem;
		margin-bottom: 0;
		line-height: 1.6;
		color: var(--home-muted);
	}
	.principle-mark {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.35rem;
		padding-top: 0.25rem;
	}
	.principle-mark span {
		display: block;
		height: 0.48rem;
		background: var(--cc-paper-line);
	}
	.principle-mark span:nth-child(1) { width: 55%; }
	.principle-mark span:nth-child(2) { width: 75%; }
	.principle-mark span:nth-child(3) { width: 100%; background: var(--layer); }

	/* Dark product stage shows how the same resolved answer reaches agents. */
	.product-stage {
		padding: clamp(5rem, 9vw, 8rem) max(1.25rem, calc((100vw - 80rem) / 2));
		background: var(--cc-canvas);
		color: var(--cc-text-body);
	}
	.product-copy {
		display: grid;
		grid-template-columns: minmax(18rem, 0.9fr) minmax(0, 1.1fr);
		gap: clamp(3rem, 8vw, 8rem);
		max-width: 80rem;
		margin: 0 auto;
	}
	.product-copy .section-number {
		color: var(--cc-layer-personal);
	}
	.product-copy h2 {
		max-width: 12ch;
		font-size: clamp(2.8rem, 5vw, 5.5rem);
		font-weight: 500;
		letter-spacing: -0.055em;
		line-height: 0.98;
		color: var(--cc-text);
	}
	:global(body.theme-paper) .product-copy h2 {
		color: var(--cc-text);
	}
	.product-detail > p {
		max-width: 34rem;
		margin-bottom: 1.75rem;
		font-size: 1.05rem;
		line-height: 1.65;
	}
	.button--light {
		background: var(--cc-text);
		border-color: var(--cc-text);
		color: var(--cc-on-cta) !important;
	}
	.stage-link {
		color: var(--cc-text) !important;
	}
	.tool-line {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4rem;
		margin-top: 2.5rem;
		font-family: var(--cc-font-mono);
		font-size: 0.68rem;
	}
	.tool-line > span {
		margin-right: 0.4rem;
		font-weight: 700;
		color: var(--cc-layer-team);
	}
	.tool-line code {
		padding: 0.3rem 0.5rem;
		border: 1px solid var(--cc-border-strong);
		color: var(--cc-text-body);
	}
	.app-window {
		min-width: 0;
		background: var(--cc-paper);
		border: 1px solid var(--cc-paper-line-strong);
		border-radius: var(--cc-radius-lg);
		box-shadow: 1.15rem 1.15rem 0 color-mix(in srgb, var(--cc-layer-company) 28%, transparent);
		overflow: hidden;
	}
	.app-window--hero {
		align-self: center;
	}
	.app-window figcaption {
		padding: 0.65rem 1rem;
		border-top: 1px solid var(--cc-paper-line);
		font-family: var(--cc-font-mono);
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--cc-ink-muted);
	}
	.window-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.8rem 1rem;
		border-bottom: 1px solid var(--cc-paper-line);
		color: var(--cc-ink);
	}
	.window-brand {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-weight: 700;
	}
	.window-brand img {
		border-radius: 0.45rem;
	}
	.window-dots {
		display: flex;
		gap: 0.35rem;
	}
	.window-dots span {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--cc-paper-line-strong);
	}
	.window-body {
		display: grid;
		grid-template-columns: 9rem minmax(0, 1fr);
		min-height: 28rem;
		color: var(--cc-ink-body);
	}
	.window-body nav {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1rem 0.75rem;
		border-right: 1px solid var(--cc-paper-line);
	}
