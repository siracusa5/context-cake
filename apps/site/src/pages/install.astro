---
// Install page: the public archive-first path plus truthful status for the
// native/package-manager channels owned by the distribution spec.
import Base from '../layouts/Base.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Icon from '../components/Icon.astro';
import demo from '../data/demo-cascade.json';

const version = '0.2.0';
const tag = `console-v${version}`;
const archiveName = `context-cake-${tag}.tar.gz`;
const archiveSha256 = '013525569cd3c3cdfac77d22bf1976a1d0bc6e8ffcbdcfbbaa8bd92502bc4253';
const sourceDownloadUrl = `https://github.com/ContextCake/context-cake/archive/refs/tags/${tag}.tar.gz`;
const tagUrl = `https://github.com/ContextCake/context-cake/tree/${tag}`;
const appDownloadUrl = 'https://github.com/ContextCake/context-cake/releases/download/app-v0.1.0/ContextCake-0.1.0-arm64.dmg';
const appReleaseUrl = 'https://github.com/ContextCake/context-cake/releases/tag/app-v0.1.0';

const terminalDownload = `curl --fail --location ${sourceDownloadUrl} \\
  --output ${archiveName}`;
const githubCliCheckout = `gh repo clone ContextCake/context-cake contextcake -- \\
  --branch ${tag} --depth 1
cd contextcake`;
const gitCheckout = `git clone --branch ${tag} --depth 1 \\
  https://github.com/ContextCake/context-cake.git contextcake
cd contextcake`;
const unpackCommand = `printf '%s  %s\\n' '${archiveSha256}' '${archiveName}' | shasum -a 256 --check &&
mkdir contextcake &&
tar -xzf ${archiveName} -C contextcake --strip-components=1 &&
cd contextcake`;
const resolveCommand = 'node resolver.mjs --manifest playground/manifest.json --concept decisions/primary-db';
const connectCommand = `claude mcp add contextcake -- \\
  node "$PWD/mcp-server.mjs" \\
  --manifest "$PWD/playground/manifest.json"`;

const demoConceptId = 'decisions/primary-db';
const primaryDb = demo.concepts.find((concept) => concept.id === demoConceptId);
if (!primaryDb) throw new Error(`Install demo concept ${demoConceptId} is missing`);

const resolvedChoice = primaryDb.sections.find(
	(section) => section.key === 'choice' && !section.suppressed,
);
if (!resolvedChoice) throw new Error('Install demo choice section is missing');

const conflict = resolvedChoice.conflicts?.[0];
const summarize = (value: string, limit = 110) => {
	const oneLine = value.replace(/\s+/g, ' ').trim();
	return oneLine.length > limit ? `${oneLine.slice(0, limit).trimEnd()}…` : oneLine;
};
const dateFormatter = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
	timeZone: 'UTC',
});
const formatDate = (iso: string) => dateFormatter.format(new Date(`${iso}T00:00:00Z`));
---

<Base
	tone="dark"
	title="Install ContextCake"
	description="Download ContextCake, verify the resolver, and connect your first AI agent in a few minutes."
>
	<main class="install-page">
		<section class="install-hero" aria-labelledby="install-title">
			<div class="hero-copy">
				<p class="eyebrow"><span>Install</span> · {tag}</p>
				<h1 id="install-title">From download to a sourced answer in five minutes.</h1>
				<p class="lede">
					ContextCake runs on plain Node.js with zero runtime dependencies. Download one
					versioned archive, resolve the bundled example, then connect the same engine to
					your agent.
				</p>
				<div class="hero-actions" aria-label="Install actions">
					<a class="button button--primary" href={appDownloadUrl} download>
						<Icon name="download" size={18} />
						Download the Mac app
					</a>
					<a class="button button--primary" href="#download">
						<span class="prompt-mark" aria-hidden="true">$</span>
						Choose an install method
					</a>
					<a class="button button--quiet" href={sourceDownloadUrl} download>
						<Icon name="download" size={18} />
						Download {tag}
					</a>
				</div>
				<ul class="hero-facts" aria-label="Install requirements">
					<li>Signed Mac app · Apple silicon</li>
					<li>Node.js 18+ for source</li>
					<li>macOS, Linux, or WSL</li>
					<li>No <code>npm install</code></li>
				</ul>
			</div>

			<figure class="install-map" aria-label="ContextCake setup path">
				<div class="map-header">
					<span>Setup path</span>
					<span class="map-status"><i></i> 4 steps</span>
				</div>
				<ol>
					<li style="--step-color: var(--cc-layer-company)">
						<span>01</span>
						<div><strong>Choose a route</strong><small>Archive, GitHub CLI, or Git</small></div>
					</li>
					<li style="--step-color: var(--cc-layer-team)">
						<span>02</span>
						<div><strong>Verify + unpack</strong><small>SHA-256, then one local folder</small></div>
					</li>
					<li style="--step-color: var(--cc-layer-team)">
						<span>03</span>
						<div><strong>Resolve</strong><small>See provenance and conflicts</small></div>
					</li>
					<li style="--step-color: var(--cc-layer-personal)">
						<span>04</span>
						<div><strong>Connect</strong><small>Serve the same graph over MCP</small></div>
					</li>
				</ol>
				<figcaption>
					<span>Program files</span>
					<strong>Local and inspectable</strong>
				</figcaption>
			</figure>
		</section>

		<section class="quickstart" id="quickstart" aria-labelledby="quickstart-title">
			<aside class="quickstart-nav">
				<p>Quickstart</p>
				<h2 id="quickstart-title">Get it running</h2>
				<nav aria-label="Install steps">
					<a href="#download"><span>01</span> Get ContextCake</a>
					<a href="#unpack"><span>02</span> Verify and unpack</a>
					<a href="#resolve"><span>03</span> Prove it works</a>
					<a href="#connect"><span>04</span> Connect an agent</a>
				</nav>
				<div class="local-note">
					<Icon name="shield" size={17} />
					<p><strong>Nothing installs globally.</strong> Delete the folder and ContextCake is gone.</p>
				</div>
			</aside>

			<div class="steps">
				<article class="install-step" id="download">
					<header class="step-heading">
						<span>01</span>
						<div>
							<p>Choose a route</p>
							<h2>Get ContextCake</h2>
						</div>
					</header>
					<p class="step-intro">
						Choose how you want to get the same tagged source. Archive routes preserve an
						explicit checksum step; Git routes are convenient when you already use source tools.
					</p>
					<div class="route-grid">
						<section class="route route--recommended" aria-labelledby="terminal-route-title">
							<div class="route-topline">
								<span class="route-badge">Recommended</span>
								<span class="route-platform">macOS · Linux · WSL</span>
							</div>
							<h3 id="terminal-route-title">Terminal with curl</h3>
							<p>Fastest for a local evaluation. Download the universal source archive, then verify it in Step 2.</p>
							<CodeBlock lang="bash" code={terminalDownload} label="Download tagged source" copy />
							<small>Continue to Step 2 · checksum verification required</small>
						</section>

						<section class="route" aria-labelledby="browser-route-title">
							<div class="route-topline">
								<span class="route-badge route-badge--quiet">No CLI required</span>
								<Icon name="download" size={18} />
							</div>
							<h3 id="browser-route-title">Browser download</h3>
							<p>Download the same universal archive directly, then use your terminal only to verify and run it.</p>
							<a class="route-action" href={sourceDownloadUrl} download>
								Download .tar.gz <Icon name="chevron-down" size={16} />
							</a>
							<small>{archiveName} · SHA-256 {archiveSha256.slice(0, 8)}…{archiveSha256.slice(-8)}</small>
						</section>

						<section class="route" aria-labelledby="github-route-title">
							<div class="route-topline">
								<span class="route-badge route-badge--quiet">GitHub CLI</span>
								<span class="route-platform">Tagged checkout</span>
							</div>
							<h3 id="github-route-title">Clone with <code>gh</code></h3>
							<p>For GitHub CLI users who want the tagged source plus a shallow repository checkout.</p>
							<CodeBlock lang="bash" code={githubCliCheckout} label="Clone tagged source" copy />
							<small>Skip Step 2 · continue with the first run</small>
						</section>

						<section class="route" aria-labelledby="git-route-title">
							<div class="route-topline">
								<span class="route-badge route-badge--quiet">Git</span>
								<span class="route-platform">Tagged checkout</span>
							</div>
							<h3 id="git-route-title">Clone with Git</h3>
							<p>For contributors, auditors, and anyone who wants familiar source-control tooling.</p>
							<CodeBlock lang="bash" code={gitCheckout} label="Clone tagged source" copy />
							<small>Skip Step 2 · continue with the first run</small>
						</section>
					</div>
				</article>

				<article class="install-step" id="unpack">
					<header class="step-heading">
						<span>02</span>
						<div>
							<p>Keep it contained</p>
							<h2>Verify and unpack it</h2>
						</div>
					</header>
					<p class="step-intro">
						If you chose curl or the browser download, check the archive against the published
						SHA-256, then unpack it into one local folder. Git and GitHub CLI users can skip
						this step because their checkout is already ready.
					</p>
					<CodeBlock lang="bash" code={unpackCommand} label="Verify, unpack, and enter" copy />
				</article>

				<article class="install-step" id="resolve">
					<header class="step-heading">
						<span>03</span>
						<div>
							<p>First run</p>
							<h2>Prove the resolver works</h2>
						</div>
					</header>
					<p class="step-intro">
						Resolve a bundled concept where three layers disagree. The command prints the
						effective answer, its source, and the dated dissent that remains attached.
					</p>
					<CodeBlock lang="bash" code={resolveCommand} label="Resolve the demo" copy />

					<figure class="result-preview" aria-labelledby="result-title">
						<div class="result-header">
							<div>
								<span>Visible output</span>
								<h3 id="result-title">decisions/primary-db</h3>
							</div>
							<span class="result-status"><i></i> resolved</span>
						</div>
						<div class="result-row" style="--result-color: var(--cc-layer-personal)">
							<span class="result-swatch" aria-hidden="true"></span>
							<div><small>Effective choice</small><strong>{summarize(resolvedChoice.content)}</strong></div>
							<code>{resolvedChoice.sourceLayer} · {formatDate(resolvedChoice.sourceUpdated)}</code>
						</div>
						{conflict && (
							<div class="conflict-row">
								<Icon name="alert" size={16} />
								<div><small>Conflict preserved</small><span>{summarize(conflict.content, 86)}</span></div>
								<code>{conflict.layer} · {formatDate(conflict.updated)}</code>
							</div>
						)}
						<figcaption>Generated at build time from the same demo bundle the command resolves.</figcaption>
					</figure>
				</article>

				<article class="install-step" id="connect">
					<header class="step-heading">
						<span>04</span>
						<div>
							<p>Use the graph</p>
							<h2>Connect an agent</h2>
						</div>
					</header>
					<p class="step-intro">
						Register the same engine with an MCP client. Claude Code is shown; the
						<a href="/docs/getting-started/connect-an-agent">agent connection guide</a> covers other clients.
					</p>
					<CodeBlock lang="bash" code={connectCommand} label="Claude Code" copy />
					<div class="next-actions">
						<div>
							<strong>Prefer a visual check?</strong>
							<span>Run the local playground at <code>http://127.0.0.1:8790</code>.</span>
						</div>
						<CodeBlock lang="bash" code="npm run playground" label="Local playground" copy />
					</div>
				</article>
			</div>
		</section>

		<section class="channels channels--available" id="mac-app" aria-labelledby="mac-app-title">
			<div class="section-heading">
				<p>Native app · app-v0.1.0</p>
				<h2 id="mac-app-title">A zero-terminal path for Mac.</h2>
				<span>The Apple-silicon DMG is signed, notarized, and ready to drag into Applications.</span>
			</div>
			<div class="channel-grid">
				<article>
					<div><Icon name="dashboard" size={20} /><span>Available now</span></div>
					<h3>ContextCake for Mac</h3>
					<p>Open the DMG, move ContextCake to Applications, and sign in. Install the optional CLI from the app menu.</p>
					<a class="route-action" href={appDownloadUrl} download>Download the DMG <Icon name="download" size={16} /></a>
					<small><a href={appReleaseUrl}>Release notes and checksums</a> · Apple silicon</small>
				</article>
			</div>
		</section>

		<section class="channels" id="channels" aria-labelledby="channels-title">
			<div class="section-heading">
				<p>Package managers and apps</p>
				<h2 id="channels-title">The next distribution layer.</h2>
				<span>
					Modern developer tools usually add native apps, package managers, and platform
					installers. ContextCake will only list a command once its artifact is published,
					signed where appropriate, and independently verifiable.
				</span>
			</div>
			<div class="channel-grid">
				<article>
					<div><Icon name="dashboard" size={20} /><span>Coming next</span></div>
					<h3>ContextCake for Mac</h3>
					<p>The signed release is available above. This section remains the roadmap for future universal builds and update channels.</p>
					<small>Current artifact: Apple-silicon DMG.</small>
				</article>
				<article>
					<div><Icon name="download" size={20} /><span>Planned</span></div>
					<h3>Homebrew</h3>
					<p>A familiar managed install for Mac users who want clean upgrades and removal.</p>
					<small>The cask will install the same verified application artifact.</small>
				</article>
				<article>
					<div><Icon name="dashboard" size={20} /><span>Use WSL today</span></div>
					<h3>Windows</h3>
					<p>The terminal route works in WSL today. A native Windows installer waits for a tested, signed artifact.</p>
					<small>No unverified PowerShell bootstrap command.</small>
				</article>
				<article>
					<div><Icon name="shield" size={20} /><span>Not offered</span></div>
					<h3>npm global install</h3>
					<p>The engine has zero runtime dependencies and intentionally avoids registry install scripts.</p>
					<small>Use the archive or a tagged Git checkout instead.</small>
				</article>
			</div>
		</section>

		<section class="trust" aria-labelledby="trust-title">
			<div>
				<p>Why this path</p>
				<h2 id="trust-title">An install you can inspect.</h2>
			</div>
			<div class="trust-copy">
				<p>
					Package registries are convenient, but they also add maintainer accounts,
					transitive dependencies, and lifecycle scripts to the trust chain. The current
					archive is deliberately smaller: versioned source with a published checksum,
					plain Node.js, and no
					<code>postinstall</code> step.
				</p>
				<p class="boundary-note">
					<Icon name="alert" size={18} />
					<span><strong>The manifest is still a trust boundary.</strong> An MCP source can run the command it names as your user. Only use manifests you wrote or trust.</span>
				</p>
				<div class="trust-links">
					<a href="/docs/concepts/trust-boundary">Read the trust model</a>
					<a href={tagUrl}>Inspect {tag} on GitHub <Icon name="external-link" size={15} /></a>
				</div>
				<details>
					<summary>Need a source checkout instead?</summary>
					<p>
						Use Git when you want history, a fork, or a contribution workflow. The current
						source tree keeps the demo manifest under <code>apps/playground/</code>.
					</p>
					<CodeBlock
						lang="bash"
						code={`git clone https://github.com/ContextCake/context-cake.git\ncd context-cake\nnode resolver.mjs --manifest apps/playground/manifest.json --concept decisions/primary-db`}
						label="Clone for development"
						copy
					/>
				</details>
			</div>
		</section>
	</main>
</Base>

<style>
	.install-page {
		position: relative;
		z-index: 0;
		max-width: 76rem;
		margin: 0 auto;
		padding: 5.5rem 1.5rem 0;
	}
	.install-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.72fr);
		align-items: center;
		gap: 4rem;
		min-height: 34rem;
		padding-bottom: 6rem;
	}
	.eyebrow,
	.quickstart-nav > p,
	.section-heading > p,
	.trust > div:first-child > p,
	.step-heading p {
		margin: 0;
		color: var(--cc-text-muted);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.11em;
		text-transform: uppercase;
	}
	.eyebrow span {
		color: var(--cc-layer-team);
	}
	h1 {
		max-width: 13ch;
		margin: 1.2rem 0 1.35rem;
		font-size: clamp(3rem, 6vw, 5.75rem);
		line-height: 0.95;
		letter-spacing: -0.055em;
	}
	.lede {
		max-width: 39rem;
		margin: 0;
		color: var(--cc-text-body);
		font-size: clamp(1.05rem, 1.5vw, 1.2rem);
		line-height: 1.65;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		min-height: 2.9rem;
		padding: 0.2rem 1.15rem;
		border: 1px solid var(--cc-border-strong);
		border-radius: 999px;
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
		transition:
			background var(--cc-transition),
			border-color var(--cc-transition),
			color var(--cc-transition);
	}
	.button--primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.button--primary:hover {
		border-color: var(--cc-cta-hover);
		background: var(--cc-cta-hover);
	}
	:global(body.theme-paper) .button--primary,
	:global(body.theme-paper) .route-action {
		color: var(--cc-on-cta);
	}
	.button--quiet {
		background: var(--cc-surface-soft);
		color: var(--cc-text-body);
	}
	.button--quiet:hover {
		background: color-mix(in srgb, var(--cc-layer-team) 10%, var(--cc-surface));
		color: var(--cc-text);
	}
	.hero-facts {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.4rem;
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
		color: var(--cc-text-muted);
		font-family: var(--cc-font-mono);
		font-size: 0.75rem;
	}
	.hero-facts li {
		display: flex;
		align-items: center;
		gap: 0.55rem;
	}
	.hero-facts li::before {
		content: '';
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
	}
	.hero-facts code,
	.channel-grid code {
		font-family: inherit;
	}
	.install-map {
		margin: 0;
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-xl);
		background: var(--cc-surface);
		box-shadow: var(--cc-shadow-panel);
		backdrop-filter: blur(18px);
	}
	.map-header,
	.install-map figcaption,
	.result-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.map-header {
		padding: 0.3rem 0.35rem 0.95rem;
		border-bottom: 1px solid var(--cc-border);
		color: var(--cc-text-muted);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.map-status,
	.result-status {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}
	.map-status i,
	.result-status i {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
		box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--cc-layer-team) 14%, transparent);
	}
	.install-map ol {
		display: grid;
		gap: 0.6rem;
		margin: 0;
		padding: 1rem 0;
		list-style: none;
	}
	.install-map li {
		display: grid;
		grid-template-columns: 3rem minmax(0, 1fr);
		align-items: center;
		gap: 0.8rem;
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: var(--cc-surface-soft);
	}
	.install-map li > span {
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: var(--cc-radius-sm);
		background: color-mix(in srgb, var(--step-color) 15%, var(--cc-surface-solid));
		color: var(--step-color);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
	}
	.install-map li div {
		display: grid;
		gap: 0.1rem;
	}
	.install-map li strong {
		color: var(--cc-text);
	}
	.install-map li small {
		color: var(--cc-text-muted);
	}
	.install-map figcaption {
		padding: 0.85rem 0.35rem 0.2rem;
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
	}
	.install-map figcaption span {
		color: var(--cc-text-muted);
	}
	.install-map figcaption strong {
		color: var(--cc-layer-team);
		font-weight: 500;
	}
	.quickstart {
		display: grid;
		grid-template-columns: 15rem minmax(0, 1fr);
		gap: 4.5rem;
		padding: 5.5rem 0;
		border-top: 1px solid var(--cc-border);
	}
	.quickstart-nav {
		position: sticky;
		top: 2rem;
		align-self: start;
	}
	.quickstart-nav h2 {
		margin: 0.55rem 0 1.5rem;
		font-size: 1.8rem;
		letter-spacing: -0.03em;
	}
	.quickstart-nav nav {
		display: grid;
		gap: 0.1rem;
	}
	.quickstart-nav nav a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-height: 2.75rem;
		padding: 0 0.6rem;
		border-radius: var(--cc-radius-sm);
		color: var(--cc-text-body);
		font-size: 0.9rem;
		text-decoration: none;
		transition: background var(--cc-transition), color var(--cc-transition);
	}
	.quickstart-nav nav a:hover {
		background: var(--cc-surface-soft);
