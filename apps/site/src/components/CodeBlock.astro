---
import { codeToHtml } from 'shiki';
import Icon from './Icon.astro';

interface Props {
	className?: string;
	code: string;
	lang: string;
	label?: string;
	copy?: boolean;
}

const { className = '', code, lang, label, copy = false } = Astro.props;
const html = await codeToHtml(code, {
	lang,
	theme: 'github-dark-default',
});
---

<div class={`code-block ${className}`.trim()}>
	{(label || copy) && (
		<div class="code-toolbar">
			{label ? <span>{label}</span> : <span class="sr-only">Command</span>}
			{copy && (
				<button type="button" data-copy-code data-code={code} aria-label={`Copy ${label ?? 'code'} to clipboard`}>
					<Icon name="copy" size={15} />
					<span class="copy-label" aria-live="polite">Copy</span>
				</button>
			)}
		</div>
	)}
	<div class="code-content" set:html={html} />
</div>

<style>
	.code-block {
		overflow: auto;
		border: 1px solid color-mix(in srgb, var(--cc-paper) 13%, transparent);
		border-radius: var(--cc-radius-md);
		background: var(--cc-ink);
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	.code-toolbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 2.5rem;
		padding: 0.35rem 0.55rem 0.35rem 1rem;
		border-bottom: 1px solid color-mix(in srgb, var(--cc-paper) 13%, transparent);
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.code-toolbar button {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		min-height: 2rem;
		padding: 0.3rem 0.65rem;
		border: 1px solid color-mix(in srgb, var(--cc-paper) 16%, transparent);
		border-radius: 999px;
		background: color-mix(in srgb, var(--cc-paper) 5%, transparent);
		color: var(--cc-paper);
		font: inherit;
		letter-spacing: 0;
		text-transform: none;
		cursor: pointer;
		transition:
			border-color var(--cc-transition),
			background var(--cc-transition),
			color var(--cc-transition);
	}
	.code-toolbar button:hover,
	.code-toolbar button.copied {
		border-color: var(--cc-border-strong);
		background: color-mix(in srgb, var(--cc-layer-team) 12%, var(--cc-ink));
		color: var(--cc-paper);
	}
	.code-content :global(.shiki) {
		margin: 0;
		padding: 1rem 1.1rem;
		background: transparent !important;
		font-family: var(--cc-font-mono);
		font-size: 0.88rem;
		line-height: 1.65;
	}
	.code-content :global(.shiki code) {
		white-space: pre;
	}
	@media (max-width: 620px) {
		.code-content :global(.shiki) {
			font-size: 0.84rem;
		}
	}
</style>

<script>
	function copyWithTextarea(text: string): boolean {
		const textarea = document.createElement('textarea');
		textarea.value = text;
		textarea.setAttribute('readonly', '');
		textarea.style.position = 'fixed';
		textarea.style.opacity = '0';
		document.body.appendChild(textarea);
		textarea.select();

		try {
			return document.execCommand('copy');
		} catch {
			return false;
		} finally {
			textarea.remove();
		}
	}

	async function copyCode(text: string): Promise<boolean> {
		if (navigator.clipboard && window.isSecureContext) {
			try {
				await navigator.clipboard.writeText(text);
				return true;
			} catch {
				/* fall through to the textarea fallback */
			}
		}

		return copyWithTextarea(text);
	}

	function selectVisibleCode(button: HTMLButtonElement) {
		const code = button.closest('.code-block')?.querySelector<HTMLElement>('.code-content code');
		const selection = window.getSelection();
		if (!code || !selection) return;
		const range = document.createRange();
		range.selectNodeContents(code);
		selection.removeAllRanges();
		selection.addRange(range);
	}

	for (const button of document.querySelectorAll<HTMLButtonElement>('[data-copy-code]')) {
		button.addEventListener('click', async () => {
			const label = button.querySelector('.copy-label');
			const copied = await copyCode(button.dataset.code ?? '');
			if (!copied) selectVisibleCode(button);
			button.classList.toggle('copied', copied);
			if (label) label.textContent = copied ? 'Copied' : 'Selected: press ⌘/Ctrl-C';
			setTimeout(() => {
				button.classList.remove('copied');
				if (label) label.textContent = 'Copy';
			}, 2000);
		});
	}
</script>
